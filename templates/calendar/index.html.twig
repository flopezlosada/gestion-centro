{% extends 'app_shell.html.twig' %}
{% import '_macros/task.html.twig' as taskUi %}

{% block title %}Calendario · {{ label }} · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Calendario{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Calendario de tareas</h1>
            <p class="lead">El plan de tareas del centro, por fecha límite. Cambia el nivel de zoom: día, semana, mes o año.</p>
        </div>
    </div>

    <div class="card">
        <div class="calendar-toolbar">
            <a class="btn secondary btn-sm" href="{{ path('calendar_index', { vista: view, fecha: prevDate }) }}" rel="prev">‹ Anterior</a>
            <h2 class="calendar-title">{{ label }}</h2>
            <a class="btn secondary btn-sm" href="{{ path('calendar_index', { vista: view, fecha: nextDate }) }}" rel="next">Siguiente ›</a>
        </div>

        <div class="calendar-views">
            {% set viewLabels = { dia: 'Día', semana: 'Semana', mes: 'Mes', anio: 'Año' } %}
            <nav class="calendar-views-tabs" aria-label="Nivel de zoom del calendario">
                {% for v in views %}
                    <a class="calendar-view{{ v == view ? ' is-active' }}"{{ v == view ? ' aria-current="page"' }}
                       href="{{ path('calendar_index', { vista: v, fecha: anchor|date('Y-m-d') }) }}">{{ viewLabels[v] }}</a>
                {% endfor %}
            </nav>
            <a class="btn secondary btn-sm" href="{{ path('calendar_index', { vista: view, fecha: todayDate }) }}">Hoy</a>
        </div>

        {% include template %}

        {% if view != 'dia' %}
            <ul class="calendar-legend" aria-label="Filtrar por estado (pulsa para ocultar/mostrar)">
                {% for status in ['pending', 'in_progress', 'submitted', 'done', 'validated', 'rejected'] %}
                    <li><button type="button" class="calendar-legend__toggle" data-filter-status="{{ status }}" aria-pressed="true">{{ taskUi.status_dot(status) }} {{ taskUi.status_label(status) }}</button></li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
{% endblock %}
