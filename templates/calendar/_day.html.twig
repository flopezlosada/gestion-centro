{% import '_macros/task.html.twig' as taskUi %}
{% import '_macros/calendar.html.twig' as cal %}

<div class="calendar-dayview">
    <div class="calendar-dayview-actions">
        {# Alta rápida del propio día (botón visible, no el "+" de hover de la rejilla). #}
        {{ cal.add_menu(day, 'inline') }}
    </div>

    {% if day.nonLective %}
        <p class="calendar-dayview-flag calendar-dayview-flag--nonlective">
            <span class="calendar-legend-swatch calendar-legend-swatch--nonlective"></span>
            Día no lectivo · {{ day.nonLective.description }}
        </p>
    {% elseif day.isWeekend %}
        <p class="calendar-dayview-flag">Fin de semana</p>
    {% endif %}

    {% if day.tasks is empty and day.events is empty %}
        <div class="empty-state">
            <p>No hay tareas ni eventos este día.</p>
        </div>
    {% else %}
        <ol class="agenda-list">
            {# canWork calculado en el cuerpo (aquí `is_granted`/`app` sí están disponibles) y pasado
               al macro: mismo criterio que TaskController::canWorkOn (admin o dueño de la tarea). #}
            {% for task in day.tasks %}
                {{ taskUi.agenda_item(task, is_granted('ROLE_ADMIN') or task.isOwnedBy(app.user)) }}
            {% endfor %}
            {# Los eventos personales son privados del usuario; solo llegan aquí los suyos. #}
            {% for event in day.events %}
                {{ taskUi.event_item(event) }}
            {% endfor %}
        </ol>
    {% endif %}
</div>
