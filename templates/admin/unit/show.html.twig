{% extends 'app_shell.html.twig' %}

{% block title %}{{ unit.name }}{% endblock %}

{% block breadcrumb %}
    <a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>
    <a href="{{ path('admin_unit_index') }}">Departamentos</a><span class="sep">/</span>
    {{ unit.name }}
{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>{{ unit.name }}</h1>
            <p class="lead">Jefatura: {{ head ? head.fullName : '— sin asignar —' }} <span class="help">(se asigna dando el rol de jefatura de departamento en la ficha del profesor)</span></p>
        </div>
        <a class="btn secondary" href="{{ path('admin_unit_edit', { id: unit.id }) }}">Editar</a>
    </div>

    <div class="card">
        <div class="page-head"><div><h2>Profesorado del departamento</h2></div></div>
        {% if members is empty %}
            <div class="empty-state">
                <p>Nadie asignado a este departamento todavía.</p>
            </div>
        {% else %}
            <table data-list-tools>
                <thead>
                    <tr><th>Nombre</th><th>Correo</th><th data-nosort></th></tr>
                </thead>
                <tbody>
                    {% for m in members %}
                        {% set isHead = head and m.id == head.id %}
                        <tr>
                            <td>{{ m.fullName }}{% if isHead %} <span class="badge">Jefatura</span>{% endif %}</td>
                            <td class="mono">{{ m.email }}</td>
                            <td class="row-actions">
                                <form method="post" action="{{ path('admin_unit_remove_member', { id: unit.id, userId: m.id }) }}" data-confirm="¿Quitar a {{ m.fullName }} del departamento?">
                                    <input type="hidden" name="_token" value="{{ csrf_token('unit_remove_member' ~ m.id) }}">
                                    <button type="submit" class="link-danger">Quitar</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    <div class="card">
        <div class="page-head">
            <div>
                <h2>Añadir profesorado</h2>
                <p class="lead">Busca a alguien que ya esté dado de alta y añádelo (si estaba en otro departamento, se mueve), o crea una persona nueva.</p>
            </div>
            <a class="btn" href="{{ path('admin_user_new', { unit: unit.id }) }}">+ Nuevo profesor</a>
        </div>
        {% if candidates is empty %}
            <p class="help">No hay más personas que añadir.</p>
        {% else %}
            <table data-list-tools>
                <thead>
                    <tr><th>Nombre</th><th data-filter>Departamento actual</th><th data-nosort></th></tr>
                </thead>
                <tbody>
                    {% for c in candidates %}
                        <tr>
                            <td>{{ c.fullName }}</td>
                            <td>{{ c.unit ? c.unit.name : '— sin departamento —' }}</td>
                            <td class="row-actions">
                                <form method="post" action="{{ path('admin_unit_add_member', { id: unit.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('unit_add_member' ~ unit.id) }}">
                                    <input type="hidden" name="user" value="{{ c.id }}">
                                    <button type="submit" class="link-action">Añadir</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
