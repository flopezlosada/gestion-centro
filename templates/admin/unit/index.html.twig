{% extends 'app_shell.html.twig' %}

{% block title %}Unidades{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Organigrama{% endblock %}

{# Nodo del árbol: se pinta a sí mismo y, recursivamente, sus unidades hijas. Materializa la cadena
   de mando (Unit.parent), de la que dependen el escalado y la validación. #}
{% macro node(unit) %}
    <li>
        <div class="unit-node {{ unit.active ? '' : 'unit-node--inactive' }}">
            <a class="unit-node__name" href="{{ path('admin_unit_edit', { id: unit.id }) }}">{{ unit.name }}</a>
            <span class="mono muted unit-node__code">{{ unit.code }}</span>
            {% if not unit.active %}<span class="badge badge--draft">Inactiva</span>{% endif %}
            <span class="unit-node__meta">Responsable: {{ unit.manager ? unit.manager.fullName : '— sin asignar —' }}</span>
            <a class="unit-node__edit" href="{{ path('admin_unit_edit', { id: unit.id }) }}">Editar</a>
        </div>
        {% if unit.children|length > 0 %}
            <ul>
                {% for child in unit.children %}
                    {{ _self.node(child) }}
                {% endfor %}
            </ul>
        {% endif %}
    </li>
{% endmacro %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Organigrama</h1>
            <p class="lead">Las unidades del centro y su cadena de mando. Cada unidad tiene un responsable que valida sus tareas y recibe los escalados.</p>
        </div>
        <a class="btn" href="{{ path('admin_unit_new') }}">+ Nueva unidad</a>
    </div>

    <div class="card">
        {% if roots is empty %}
            <div class="empty-state">
                <h2>No hay unidades todavía</h2>
                <p>Crea la primera unidad (normalmente el equipo directivo, en la cúspide de la jerarquía).</p>
                <a class="btn" href="{{ path('admin_unit_new') }}">Nueva unidad</a>
            </div>
        {% else %}
            <ul class="unit-tree">
                {% for unit in roots %}
                    {{ _self.node(unit) }}
                {% endfor %}
            </ul>
        {% endif %}
    </div>
{% endblock %}
