{% extends 'app_shell.html.twig' %}

{% block title %}Roles{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Roles y permisos{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Roles y permisos</h1>
            <p class="lead">Cada rol define qué puede leer o escribir en cada área. Las personas heredan el acceso de sus roles.</p>
        </div>
        <a class="btn" href="{{ path('admin_role_new') }}">+ Nuevo rol</a>
    </div>

    <div class="card">
        {% if roles is empty %}
            <div class="empty-state">
                <h2>No hay roles todavía</h2>
                <p>Crea el primer rol y define sus permisos por área.</p>
                <a class="btn" href="{{ path('admin_role_new') }}">Nuevo rol</a>
            </div>
        {% else %}
            <table data-list-tools>
                <thead>
                    <tr><th>Nombre</th><th>Código</th><th data-nosort></th></tr>
                </thead>
                <tbody>
                    {% for role in roles %}
                        <tr>
                            <td><a href="{{ path('admin_role_edit', { id: role.id }) }}">{{ role.name }}</a></td>
                            <td class="mono muted">{{ role.code }}</td>
                            <td class="row-actions"><a href="{{ path('admin_role_edit', { id: role.id }) }}">Editar</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
