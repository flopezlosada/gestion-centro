{% extends 'base.html.twig' %}

{# Layout principal: barra lateral + cabecera + contenido. Las pantallas con sesión extienden
   ESTE archivo y rellenan {% block body %}; el login extiende 'base.html.twig' directamente. #}

{% set route = app.request.attributes.get('_route') %}
{% set unread = unread_notifications() %}

{% block shell %}
    <div class="layout">
        <aside class="sidebar">
            <div class="sidebar-head">
                <a class="brand" href="{{ path('personal_event_index') }}">
                    <span class="brand-mark">{{ include('partials/_brand_mark.html.twig', { size: 30 }) }}</span>
                    <span class="brand-name">Gestión del centro</span>
                </a>
                <button class="nav-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="main-nav">
                    <span class="nav-toggle-bars"></span>
                </button>
            </div>

            <nav id="main-nav" class="nav" aria-label="Navegación principal">
                <a href="{{ path('app_homepage') }}" class="{{ route == 'app_homepage' ? 'is-active' }}">Inicio</a>
                <a href="{{ path('personal_event_index') }}" class="{{ route starts with 'personal_event_' ? 'is-active' }}">Agenda personal</a>
                <a href="{{ path('task_index') }}" class="{{ route starts with 'task_' ? 'is-active' }}">Tareas del centro</a>
                <a href="{{ path('guardia_mine') }}" class="{{ route == 'guardia_mine' ? 'is-active' }}">Mis guardias</a>
                <a href="{{ path('calendar_index') }}" class="{{ route starts with 'calendar_' ? 'is-active' }}">Calendario</a>
                <a href="{{ path('notification_index') }}" class="{{ route starts with 'notification_' ? 'is-active' }}">Avisos{% if unread > 0 %} <span class="badge badge--danger">{{ unread }}</span>{% endif %}</a>

                {# Gestión de guardias: solo para quien coordina (lectura en el área Guardias; el flag de
                   administrador la concede por bypass). Las acciones del parte exigen escritura, verificada
                   en el GuardiaController con el mismo AreaVoter. #}
                {% if is_granted(constant('App\\Security\\Voter\\AreaVoter::READ'), constant('App\\Enum\\Area::GUARDIAS')) %}
                    <span class="nav-section-title">Guardias</span>
                    <div class="nav-group">
                        <a href="{{ path('guardia_index') }}" class="{{ (route == 'guardia_index' or route starts with 'guardia_absence') ? 'is-active' }}">Parte del día</a>
                        <a href="{{ path('guardia_history') }}" class="{{ route == 'guardia_history' ? 'is-active' }}">Histórico</a>
                        <a href="{{ path('guardia_stats') }}" class="{{ route == 'guardia_stats' ? 'is-active' }}">Estadísticas</a>
                        {% if is_granted(constant('App\\Security\\Voter\\AreaVoter::WRITE'), constant('App\\Enum\\Area::GUARDIAS')) %}
                            <a href="{{ path('guardia_schedule_edit') }}" class="{{ route starts with 'guardia_schedule_' ? 'is-active' }}">Horario de guardias</a>
                        {% endif %}
                    </div>
                {% endif %}

                {# Administración: alta de personas, roles/permisos y organigrama. Visible para quien
                   tenga escritura en el área Administración (el flag de administrador la concede por
                   completo); los controladores /admin aplican el mismo gate con el AreaVoter. #}
                {% if is_granted(constant('App\\Security\\Voter\\AreaVoter::WRITE'), constant('App\\Enum\\Area::ADMINISTRATION')) %}
                    <span class="nav-section-title">Administración</span>
                    <div class="nav-group">
                        <a href="{{ path('admin_user_index') }}" class="{{ route starts with 'admin_user_' ? 'is-active' }}">Usuarios</a>
                        <a href="{{ path('admin_role_index') }}" class="{{ route starts with 'admin_role_' ? 'is-active' }}">Roles y permisos</a>
                        <a href="{{ path('admin_department_index') }}" class="{{ route starts with 'admin_department_' ? 'is-active' }}">Departamentos</a>
                        <a href="{{ path('admin_task_template_index') }}" class="{{ route starts with 'admin_task_template_' ? 'is-active' }}">Catálogo de tareas</a>
                        <a href="{{ path('admin_academic_year_index') }}" class="{{ route starts with 'admin_academic_year_' ? 'is-active' }}">Años escolares</a>
                        <a href="{{ path('admin_timetable_import') }}" class="{{ route starts with 'admin_timetable_' ? 'is-active' }}">Horario (Peñalara)</a>
                        <a href="{{ path('admin_non_lective_day_index') }}" class="{{ route starts with 'admin_non_lective_day_' ? 'is-active' }}">Días no lectivos</a>
                        <a href="{{ path('admin_event_category_index') }}" class="{{ route starts with 'admin_event_category_' ? 'is-active' }}">Categorías de evento</a>
                    </div>
                {% endif %}

                {# Cuenta (tema + usuario + salir): en móvil la topbar se oculta, así que estos controles
                   viven aquí, en el cajón "Más". En escritorio este bloque se oculta (manda la topbar). #}
                <div class="nav-account">
                    <span class="nav-account__user">
                        <span class="avatar">{{ app.user.fullName|split(' ')|map(w => w|first)|join|slice(0, 2)|upper }}</span>
                        <span class="nav-account__name">{{ app.user.fullName }}</span>
                    </span>
                    <div class="theme-toggle" role="group" aria-label="Tema de color">
                        <button type="button" data-theme-value="light" aria-pressed="true">Claro</button>
                        <button type="button" data-theme-value="dark" aria-pressed="false">Oscuro</button>
                    </div>
                    <a href="{{ path('app_logout') }}" class="nav-account__logout">Cerrar sesión</a>
                </div>
            </nav>

            <div class="nav-backdrop"></div>

            <div class="sidebar-foot">
                {{ app_organization_name }}<br>
                Gestión del día a día
            </div>
        </aside>

        <div class="main">
            <header class="topbar">
                <nav class="breadcrumb" aria-label="Ruta">
                    {% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a>{% endblock %}
                </nav>
                <div class="topbar-right">
                    <div class="theme-toggle" role="group" aria-label="Tema de color">
                        <button type="button" data-theme-value="light" aria-pressed="true">Claro</button>
                        <button type="button" data-theme-value="dark" aria-pressed="false">Oscuro</button>
                    </div>
                    {% if app.user %}
                        <span class="user">
                            <span class="avatar">{{ app.user.fullName|split(' ')|map(w => w|first)|join|slice(0, 2)|upper }}</span>
                            <span>{{ app.user.fullName }}</span>
                            <span aria-hidden="true">·</span>
                            <a href="{{ path('app_logout') }}">Salir</a>
                        </span>
                    {% endif %}
                </div>
            </header>

            <main class="page">
                {# Invitación a activar los avisos push en este dispositivo. Oculta por defecto; push.js la
                   muestra solo si el navegador lo soporta, no está bloqueado ni ya suscrito, y no se ha
                   descartado. El permiso del navegador exige un click, así que es un botón, no un prompt. #}
                {% if app.user and app_vapid_public_key is not empty %}
                    <div class="push-cta" data-push-banner hidden>
                        <span class="push-cta__text">Activa los avisos en este dispositivo para enterarte al momento cuando te asignen una guardia.</span>
                        <span class="push-cta__actions">
                            <button type="button" class="btn" data-push-banner-activate>Activar avisos</button>
                            <button type="button" class="btn secondary" data-push-banner-dismiss>Ahora no</button>
                        </span>
                    </div>
                {% endif %}

                {% for message in app.flashes('success') %}
                    <div class="flash success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash error">{{ message }}</div>
                {% endfor %}

                {% block body %}{% endblock %}
            </main>
        </div>

        {# Barra inferior móvil: 5 destinos para el pulgar. Oculta en escritorio (el sidebar manda).
           Fuera de .main (hija de .layout) para que su posicionamiento fijo no dependa de esa columna.
           "Más" abre el mismo cajón de navegación que la hamburguesa (data-nav-toggle → nav.js).
           Es un bloque para que las pantallas "empujadas" (detalle, formularios) la oculten y usen su
           propia barra de acciones. #}
        {% block bottomnav %}
        <nav class="bottomnav" aria-label="Navegación">
                <a href="{{ path('app_homepage') }}" class="bottomnav__item{{ route == 'app_homepage' ? ' is-active' }}"{{ route == 'app_homepage' ? ' aria-current=page' }}>
                    <span class="bottomnav__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V20h14V9.5"/></svg></span>
                    <span>Inicio</span>
                </a>
                <a href="{{ path('task_index') }}" class="bottomnav__item{{ route starts with 'task_' ? ' is-active' }}"{{ route starts with 'task_' ? ' aria-current=page' }}>
                    <span class="bottomnav__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6h11M9 12h11M9 18h11"/><path d="M4 6l1 1 1.5-1.5M4 12l1 1 1.5-1.5M4 18l1 1 1.5-1.5"/></svg></span>
                    <span>Tareas</span>
                </a>
                <a href="{{ path('guardia_mine') }}" class="bottomnav__item{{ route starts with 'guardia_' ? ' is-active' }}"{{ route starts with 'guardia_' ? ' aria-current=page' }}>
                    <span class="bottomnav__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
                    <span>Guardias</span>
                </a>
                <a href="{{ path('notification_index') }}" class="bottomnav__item{{ route starts with 'notification_' ? ' is-active' }}"{{ route starts with 'notification_' ? ' aria-current=page' }}>
                    <span class="bottomnav__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6"/><path d="M10 20a2 2 0 0 0 4 0"/></svg>{% if unread > 0 %}<span class="bottomnav__dot" aria-hidden="true"></span>{% endif %}</span>
                    <span>Avisos{% if unread > 0 %} <span class="visually-hidden">({{ unread }} sin leer)</span>{% endif %}</span>
                </a>
                <button type="button" class="bottomnav__item" data-nav-toggle aria-expanded="false" aria-controls="main-nav">
                    <span class="bottomnav__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg></span>
                    <span>Más</span>
                </button>
            </nav>
        {% endblock %}
    </div>
{% endblock %}
