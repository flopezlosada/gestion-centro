{% extends 'app_shell.html.twig' %}
{% import '_macros/form.html.twig' as f %}

{% block title %}Nueva tarea · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('task_index') }}">Tareas</a><span class="sep">/</span>Nueva{% endblock %}

{# Pantalla empujada: sin barra de pestañas. #}
{% block bottomnav %}{% endblock %}

{% block body %}
    <div class="formtop">
        <a class="formtop__cancel" href="{{ path('task_index') }}">Cancelar</a>
        <span class="formtop__title">Nueva tarea</span>
        <span class="formtop__spacer"></span>
    </div>

    <div class="formscreen">
        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
        {{ f.submit_error(form) }}
        {{ form_errors(form) }}
        <div class="stackform stackform--screen">
            <div class="form-row">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, { attr: { class: 'field-title', placeholder: 'Ej. Preparar la evaluación', autofocus: true } }) }}
                {{ form_errors(form.title) }}
            </div>
            {{ f.field(form.description) }}
            {{ f.field(form.dueDate) }}
            {{ f.responsibility(form) }}
            {{ f.toggles([form.mandatory]|merge(form.requiresDocument is defined ? [form.requiresDocument] : [])) }}
            <div class="stackform__foot">
                <button class="btn-lg btn-lg--primary" type="submit">Crear tarea</button>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
