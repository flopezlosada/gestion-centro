{% extends 'app_shell.html.twig' %}
{% import '_macros/task.html.twig' as taskUi %}

{% block title %}{{ task.title }} · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('task_index') }}">Tareas</a><span class="sep">/</span>{{ task.title }}{% endblock %}

{% block body %}
    {% set nextStep = {
        'pending': 'Pendiente. Cuando la termines, entrégala.',
        'submitted': 'Entregada. A la espera de que un responsable la valide.',
        'validated': 'Finalizada. Tarea cerrada.',
        'cancelled': 'Cancelada. Esta tarea se anuló.',
    } %}
    {% set primaryActions = ['submit', 'validate'] %}
    {% set typeHelp = {
        'simple': 'Tarea sencilla: la entregas y un responsable la valida.',
        'with_deliverable': 'Lleva un entregable: al entregar adjuntas el enlace del documento y un responsable la valida.',
    } %}

    <div class="page-head">
        <div>
            <h1>{{ task.title }}</h1>
            <p class="lead">{{ taskUi.status_badge(task.status) }} · {{ task.type.label }}{% if not task.mandatory %} · Voluntaria{% endif %}</p>
            <p class="muted">{{ typeHelp[task.type.value]|default('') }}</p>
        </div>
        {% if canManage %}
            <div><a class="btn btn-secondary" href="{{ path('task_edit', { id: task.id }) }}">Editar</a></div>
        {% endif %}
    </div>

    <section class="card">
        <div class="page-head"><div><h2>Descripción</h2></div></div>
        {% if task.description %}<p>{{ task.description|nl2br }}</p>{% else %}<p class="muted">Esta tarea no tiene descripción.</p>{% endif %}
    </section>

    {# Puesto de trabajo: el estado en palabras + las acciones que este usuario puede hacer ahora. #}
    <section class="card task-workbench">
        <p class="task-nextstep">{{ nextStep[task.status]|default('') }}</p>
        {% if actions is not empty %}
            <div class="task-actions">
                {% for name in actions %}
                    <form method="post" action="{{ path('task_transition', { id: task.id, transition: name }) }}"{% if name == 'cancel' %} data-confirm="¿Cancelar esta tarea? Quedará anulada."{% endif %}>
                        <input type="hidden" name="_token" value="{{ csrf_token('task_transition' ~ task.id) }}">
                        {# Entregar con entregable: el enlace del documento se adjunta aquí mismo (un solo paso). #}
                        {% if name == 'submit' and task.requiresDocument %}
                            <input type="url" name="reference" value="{{ task.deliverableReference }}" placeholder="https://cloud.educa.madrid.org/…" class="deliverable-input" required>
                        {% endif %}
                        <button type="submit" class="btn{{ name in primaryActions ? '' : (name == 'cancel' ? ' btn-danger' : ' btn-secondary') }}">{{ taskUi.action_label(name) }}</button>
                    </form>
                {% endfor %}
            </div>
        {% elseif task.status in ['validated', 'cancelled'] %}
            <p class="muted">No hay nada más que hacer aquí.</p>
        {% else %}
            <p class="muted">No tienes acciones disponibles sobre esta tarea.</p>
        {% endif %}
    </section>

    {% if task.requiresDocument %}
        <section class="card">
            <div class="page-head"><div><h2>Entregable</h2><p class="lead">Enlace o referencia al documento (vive en la nube del centro; aquí solo guardamos la referencia).</p></div></div>
            {% if task.deliverableReference %}
                {# La referencia apunta a un documento real en la nube del centro: se muestra solo a las
                   personas implicadas y a sus superiores/admin (canSeeHistory), no a cualquiera que abra
                   el detalle (el acceso al detalle es universal). #}
                {% if canSeeHistory %}
                    <p><strong>Referencia:</strong> {% if task.deliverableReference starts with 'http' %}<a href="{{ task.deliverableReference }}" target="_blank" rel="noopener">{{ task.deliverableReference }}</a>{% else %}{{ task.deliverableReference }}{% endif %}</p>
                {% else %}
                    <p class="muted">Hay un entregable, pero no tienes acceso a su referencia.</p>
                {% endif %}
            {% else %}
                <p class="muted">Aún no hay entregable. El enlace se adjunta al <strong>entregar</strong> la tarea, en el mismo paso.</p>
            {% endif %}
            {# Corrección del enlace SOLO tras la entrega (estado Entregada) y antes de que se valide: al
               entregar ya se adjunta, así que no hay un "Guardar" suelto en Pendiente que confunda. #}
            {% if canWork and task.status == 'submitted' %}
                <form method="post" action="{{ path('task_set_deliverable', { id: task.id }) }}" class="deliverable-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('task_deliverable' ~ task.id) }}">
                    <input type="url" name="reference" value="{{ task.deliverableReference }}" placeholder="https://cloud.educa.madrid.org/…" class="deliverable-input">
                    <button type="submit" class="btn btn-secondary">Actualizar enlace</button>
                </form>
            {% endif %}
        </section>
    {% endif %}

    <section class="card">
        <div class="page-head"><div><h2>Detalles</h2></div></div>
        <dl class="detail-grid">
            <dt>Curso</dt><dd>{{ task.schoolYear }}</dd>
            <dt>Fecha límite</dt><dd>{{ task.dueDate|date('d/m/Y') }}</dd>
            <dt>Unidad</dt><dd>{{ task.unit ? task.unit.name : '—' }}</dd>
            <dt>Responsable</dt>
            <dd>
                {%- set who = task.responsibleForDisplay -%}
                {{ who ? who.fullName : '—' }}
                {%- if task.responsibility %} ({{ task.responsibility.label }}){% endif -%}
                {%- if task.delegatedTo %} · delegada{% endif -%}
            </dd>
            {% if task.requiresCheckbox %}<dt>Hecha por el responsable</dt><dd>{{ task.checkboxDone ? 'Sí' : 'No' }}</dd>{% endif %}
            <dt>Creada</dt><dd>{{ task.createdAt|date('d/m/Y') }}{% if task.createdBy %} · por {{ task.createdBy.fullName }}{% endif %}</dd>
        </dl>
    </section>

    {% if canDelegate %}
        <section class="card">
            <div class="page-head"><div><h2>Delegar</h2><p class="lead">Pásala a alguien de tu equipo. Estructuralmente sigue siendo {{ task.responsibility ? task.responsibility.label : 'de su responsable' }}.</p></div></div>
            <form method="post" action="{{ path('task_delegate', { id: task.id }) }}" class="stackform">
                <input type="hidden" name="_token" value="{{ csrf_token('task_delegate' ~ task.id) }}">
                <div class="form-row">
                    <label for="delegatedTo">Delegar en</label>
                    <select name="delegatedTo" id="delegatedTo">
                        <option value="">— Sin delegar —</option>
                        {% for u in delegatable %}
                            <option value="{{ u.id }}"{{ task.delegatedTo and task.delegatedTo.id == u.id ? ' selected' : '' }}>{{ u.fullName }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="stackform__foot">
                    <button class="btn" type="submit">Guardar delegación</button>
                </div>
            </form>
        </section>
    {% endif %}

    {% if canSeeHistory %}
        <section class="card">
            <div class="page-head"><div><h2>Histórico de actividad</h2><p class="lead">Quién ha hecho qué con esta tarea.</p></div></div>
            {{ include('_partials/_activity_log.html.twig', { rows: activityRows, isAdmin: isAdmin }) }}
        </section>
    {% endif %}
{% endblock %}
