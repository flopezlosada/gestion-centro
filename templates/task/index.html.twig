{% extends 'app_shell.html.twig' %}
{% import '_macros/task.html.twig' as task %}

{% block title %}Tareas {{ schoolYear }} · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Tareas{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Tareas del centro {{ schoolYear }}</h1>
            <p class="lead">El plan de tareas del curso, por fecha límite.</p>
        </div>
    </div>

    <div class="card">
        {% if tasks is empty %}
            <div class="empty-state">
                <h2>Aún no hay tareas en {{ schoolYear }}</h2>
                <p>Cuando se planifiquen las tareas del curso aparecerán aquí.</p>
            </div>
        {% else %}
            <table data-list-tools>
                <thead>
                    <tr><th>Tarea</th><th>Unidad</th><th>Responsable</th><th>Fecha límite</th><th>Estado</th></tr>
                </thead>
                <tbody>
                    {% for t in tasks %}
                        <tr>
                            <td>
                                <a href="{{ path('task_show', { id: t.id }) }}">{{ t.title }}</a>
                                {% if not t.mandatory %} <span class="badge badge--muted">Voluntaria</span>{% endif %}
                            </td>
                            <td>{{ t.unit ? t.unit.name : '—' }}</td>
                            <td>{{ t.assignedUser ? t.assignedUser.fullName : (t.assignedRole ? t.assignedRole.name : '—') }}</td>
                            <td>{{ t.dueDate|date('d/m/Y') }}</td>
                            <td>{{ task.status_badge(t.status) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
