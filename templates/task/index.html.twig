{% extends 'app_shell.html.twig' %}
{% import '_macros/task.html.twig' as taskUi %}

{% block title %}Tareas {{ schoolYear }} · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Tareas{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Tareas del centro {{ schoolYear }}</h1>
            <p class="lead">El plan de tareas del curso, por fecha límite.</p>
            {% if years|length > 1 %}
                <nav class="year-nav" aria-label="Curso">
                    {% for y in years %}
                        <a href="{{ path('task_index', { curso: y }) }}" class="year-nav__item{{ y == schoolYear ? ' is-active' }}"{{ y == schoolYear ? ' aria-current=page' }}>{{ y }}</a>
                    {% endfor %}
                </nav>
            {% endif %}
        </div>
        <div><a class="btn" href="{{ path('task_new') }}">+ Nueva tarea</a></div>
    </div>

    <div class="card">
        {% if tasks is empty %}
            <div class="empty-state">
                <h2>Aún no hay tareas en {{ schoolYear }}</h2>
                <p>Cuando se planifiquen las tareas del curso aparecerán aquí.</p>
            </div>
        {% else %}
            <table data-list-tools>
                <thead>
                    <tr><th>Tarea</th><th data-filter="Unidad">Unidad</th><th data-filter="Rol">Rol</th><th>Responsable</th><th data-filter-range="Fecha límite">Fecha límite</th><th data-filter="Estado">Estado</th></tr>
                </thead>
                <tbody>
                    {% for t in tasks %}
                        {% set responsibleRole = t.responsibility ? t.responsibility.role.name : (t.assignedRole ? t.assignedRole.name : null) %}
                        {# Vencida = abierta (no validada) y con fecha límite pasada. |date(...,false) para no
                           desplazar la fecha almacenada por zona horaria (ver memoria CI UTC vs Madrid). #}
                        {% set overdue = t.status not in ['validated', 'cancelled'] and t.dueDate|date('Y-m-d', false) < 'now'|date('Y-m-d') %}
                        <tr>
                            <td>
                                <a class="cell-link" href="{{ path('task_show', { id: t.id }) }}">{{ t.title }}</a>
                                {% if not t.mandatory %} <span class="badge badge--muted">Voluntaria</span>{% endif %}
                            </td>
                            <td>{{ t.unit ? t.unit.name : '—' }}</td>
                            <td>{{ responsibleRole ?? '—' }}</td>
                            <td>{{ taskUi.person(t.assignedUser) }}</td>
                            <td class="{{ overdue ? 'due-overdue' }}">{{ t.dueDate|date('d/m/Y') }}</td>
                            <td>{{ taskUi.status_chip(t.status) }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
