{% extends 'app_shell.html.twig' %}
{% import '_macros/form.html.twig' as f %}

{% block title %}Editar: {{ task.title }} · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('task_index') }}">Tareas</a><span class="sep">/</span><a href="{{ path('task_show', { id: task.id }) }}">{{ task.title }}</a><span class="sep">/</span>Editar{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Editar tarea</h1>
            <p class="lead">Cambia los datos de la tarea. El tipo no se puede cambiar.</p>
        </div>
    </div>

    <div class="card">
        {{ form_start(form) }}
        {{ form_errors(form) }}
        <div class="stackform">
            <div class="form-row">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, { attr: { class: 'field-title' } }) }}
                {{ form_errors(form.title) }}
            </div>
            {{ f.field(form.description) }}
            {{ f.field(form.dueDate) }}
            {% if form.assignedUser is defined %}{{ f.field(form.assignedUser) }}{% endif %}
            {% if form.assignedRole is defined %}{{ f.field(form.assignedRole) }}{% endif %}
            {{ f.toggles([form.mandatory]) }}
            <div class="stackform__foot">
                <a class="btn secondary" href="{{ path('task_show', { id: task.id }) }}">Cancelar</a>
                <button class="btn" type="submit">Guardar</button>
            </div>
        </div>
        {{ form_end(form) }}
    </div>

    <div class="card">
        <div class="page-head"><div><h2>Borrar</h2><p class="lead">Elimina la tarea. No se puede deshacer.</p></div></div>
        <form method="post" action="{{ path('task_delete', { id: task.id }) }}" data-confirm="¿Seguro que quieres borrar «{{ task.title }}»?">
            <input type="hidden" name="_token" value="{{ csrf_token('task_delete' ~ task.id) }}">
            <button type="submit" class="btn btn-danger">Borrar tarea</button>
        </form>
    </div>
{% endblock %}
