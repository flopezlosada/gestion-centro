{% extends 'app_shell.html.twig' %}

{% block title %}Apuntar ausencia{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('guardia_index') }}">Guardias</a><span class="sep">/</span>Apuntar ausencia{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Apuntar ausencia</h1>
            <p class="lead">Elige el profesor y el día; marca las horas en las que falta y deja una tarea para cada grupo. El sistema genera y reparte las guardias.</p>
        </div>
    </div>

    <div class="card">
        {% if not hasTimetable %}
            <div class="empty-state">
                <h2>No hay horario importado para el curso {{ schoolYear }}</h2>
                <p>Sin el horario del curso no se pueden generar guardias. Impórtalo y vuelve a intentarlo.</p>
                {% if is_granted(constant('App\\Security\\Voter\\AreaVoter::WRITE'), constant('App\\Enum\\Area::ADMINISTRATION')) %}
                    <p><a class="btn" href="{{ path('admin_timetable_import') }}">Importar horario</a></p>
                {% endif %}
            </div>
        {% else %}
            {# Paso 1 · quién y qué día. Cambiar cualquiera recarga la lista de clases (GET). #}
            <form method="get" action="{{ path('guardia_absence_new') }}" class="absence-picker">
                <div class="field">
                    <label for="absent_teacher">Profesor ausente</label>
                    {% if allTeachers|length == 1 %}
                        <input type="hidden" name="teacher" value="{{ allTeachers[0].id }}">
                        <p class="pill-value">{{ allTeachers[0].fullName }}</p>
                    {% else %}
                        <select id="absent_teacher" name="teacher" onchange="this.form.submit()">
                            <option value="">Elige un profesor…</option>
                            {% for teacher in allTeachers %}
                                <option value="{{ teacher.id }}" {{ teacher.id == selectedTeacher ? 'selected' }}>{{ teacher.fullName }}</option>
                            {% endfor %}
                        </select>
                    {% endif %}
                </div>
                <div class="field">
                    <label for="absence_date">Día</label>
                    <input type="date" id="absence_date" name="date" value="{{ date|date('Y-m-d', false) }}" onchange="this.form.submit()">
                </div>
                <noscript><button type="submit" class="btn secondary">Ver clases</button></noscript>
            </form>

            {# Paso 2 · clases reales de ese día del profesor elegido. #}
            {% if selectedTeacher is null %}
                <p class="muted step-hint">Elige un profesor para ver sus clases del {{ weekday.label|lower }}.</p>
            {% elseif dayClasses is empty %}
                <div class="empty-state">
                    <h2>No da clase el {{ weekday.label|lower }}</h2>
                    <p>Ese día no tiene ninguna clase lectiva, así que no hay guardias que generar. Prueba con otro día.</p>
                </div>
            {% else %}
                <form method="post" action="{{ path('guardia_absence_create') }}" class="absence-form" enctype="multipart/form-data">
                    <input type="hidden" name="_token" value="{{ csrf_token('guardia_absence_create') }}">
                    <input type="hidden" name="absent_teacher" value="{{ selectedTeacher }}">
                    <input type="hidden" name="date" value="{{ date|date('Y-m-d', false) }}">

                    <div class="page-head step-head"><div>
                        <h2>Clases del {{ weekday.label|lower }} {{ date|date('d/m/Y', false) }}</h2>
                        <p class="lead">Todas marcadas = día entero. Desmarca las horas en las que sí estará. Para cada grupo puedes adjuntar el documento con la tarea y añadir una descripción; los verá el profesor de guardia.</p>
                    </div></div>

                    <ul class="class-list">
                        {% for c in dayClasses %}
                            {% set label = c.groupCount > 1 ? (c.room ?? 'la actividad') : (c.groups|first|default('el grupo')) %}
                            <li class="class-row">
                                <label class="class-row__pick">
                                    <input type="checkbox" name="slots[]" value="{{ c.slotIndex }}" checked>
                                    <span class="class-row__time mono">{{ c.startsAt|date('H:i', false) }}–{{ c.endsAt|date('H:i', false) }}</span>
                                    <span class="class-row__group">
                                        {% if c.groupCount > 1 %}
                                            {# Actividad multigrupo (p.ej. Salón de Actos): el aula es la referencia, los grupos van listados. #}
                                            <strong>{{ c.room ?? 'Actividad de nivel' }}</strong>
                                            <span class="badge badge--muted">{{ c.groupCount }} grupos</span>
                                            <span class="muted"> · {{ c.groups|join(', ') }}</span>
                                            {% if c.subjectName %}<span class="muted"> · {{ c.subjectName }}</span>{% endif %}
                                        {% else %}
                                            <strong>{{ c.groups|first|default('—') }}</strong>
                                            {% if c.subjectName %}<span class="muted"> · {{ c.subjectName }}</span>{% endif %}
                                            {% if c.room %}<span class="muted mono"> · {{ c.room }}</span>{% endif %}
                                        {% endif %}
                                    </span>
                                </label>
                                <div class="class-row__task">
                                    <label class="class-row__file">
                                        <span class="field-label">Documento de tarea</span>
                                        <input type="file" name="documents[{{ c.slotIndex }}]">
                                    </label>
                                    <textarea name="description[{{ c.slotIndex }}]" rows="2" maxlength="1000"
                                              placeholder="Descripción para {{ label }} (opcional): lo que no venga en el documento — página, ejercicios, dónde está el examen…"></textarea>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>

                    <div class="field field--reason">
                        <label for="absence_reason">Motivo de la ausencia <span class="muted">(privado)</span></label>
                        <textarea id="absence_reason" name="reason" rows="2" maxlength="500"
                                  placeholder="Solo lo veréis el profesor ausente y la coordinación de guardias. El profesor de guardia no lo ve."></textarea>
                        <p class="field-help">Opcional. Queda guardado con la ausencia y no se muestra a quien cubre la clase.</p>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn">Apuntar ausencia</button>
                        <a class="btn secondary" href="{{ path('guardia_index', { date: date|date('Y-m-d', false) }) }}">Cancelar</a>
                    </div>
                </form>
            {% endif %}
        {% endif %}
    </div>
{% endblock %}
