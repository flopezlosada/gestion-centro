{% extends 'app_shell.html.twig' %}

{% block title %}Estadísticas de guardias{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('guardia_index') }}">Guardias</a><span class="sep">/</span>Estadísticas{% endblock %}

{% macro period_label(slotTimes, slot) %}{% set t = slotTimes[slot] ?? null %}{% if t %}{{ t.startsAt|date('H:i', false) }}–{{ t.endsAt|date('H:i', false) }}{% else %}Tramo {{ slot + 1 }}{% endif %}{% endmacro %}

{# Matriz comparativa: una fila por entidad, una columna por periodo (+ total si hay varios). #}
{% macro matrix(rows, periods, firstHeader) %}
    <table>
        <thead><tr>
            <th>{{ firstHeader }}</th>
            {% for p in periods %}<th class="mono">{{ p.label }}</th>{% endfor %}
            {% if periods|length > 1 %}<th class="mono">Total</th>{% endif %}
        </tr></thead>
        <tbody>
            {% for row in rows %}
                <tr>
                    <td>{{ row.name }}</td>
                    {% for c in row.cells %}<td class="mono">{{ c }}</td>{% endfor %}
                    {% if periods|length > 1 %}<td class="mono"><strong>{{ row.total }}</strong></td>{% endif %}
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endmacro %}

{# Tabla de datos genérica que acompaña a un gráfico: cabecera + columnas + filas {label, cells}. #}
{% macro data_table(t) %}
    <table>
        <thead><tr><th>{{ t.header }}</th>{% for c in t.columns %}<th class="mono">{{ c }}</th>{% endfor %}</tr></thead>
        <tbody>
            {% for row in t.rows %}
                <tr><td>{{ row.label }}</td>{% for c in row.cells %}<td class="mono">{{ c ?? '—' }}</td>{% endfor %}</tr>
            {% endfor %}
        </tbody>
    </table>
{% endmacro %}

{# Desglose por departamento y por profesor ausente (matrices), común a un periodo y a la comparativa. #}
{% macro breakdown(byDepartment, absentRanking, periods) %}
    {% import _self as s %}
    {% if byDepartment is not empty %}
        <div class="card">
            <div class="page-head"><div><h2>Ausencias por departamento</h2><p class="lead">Según el departamento del profesor ausente.</p></div></div>
            {{ s.matrix(byDepartment, periods, 'Departamento') }}
        </div>
    {% endif %}
    {% if absentRanking is not empty %}
        <div class="card">
            <div class="page-head"><div><h2>Profesores con más ausencias</h2><p class="lead">Top {{ absentRanking|length }} por ausencias registradas en los periodos elegidos.</p></div></div>
            {{ s.matrix(absentRanking, periods, 'Profesor') }}
        </div>
    {% endif %}
{% endmacro %}

{% block body %}
    {% import _self as s %}
    {% set weekdayNames = {1: 'Lun', 2: 'Mar', 3: 'Mié', 4: 'Jue', 5: 'Vie'} %}
    {% set termOrdinals = {1: '1er', 2: '2º', 3: '3er'} %}

    <div class="page-head">
        <div>
            <h1>Estadísticas de guardias</h1>
            <p class="lead">Elige uno o varios periodos (cursos o trimestres). Con varios, cada dato se compara lado a lado.</p>
        </div>
        <div><a class="btn secondary" href="{{ path('guardia_stats_csv') }}">Descargar CSV</a></div>
    </div>

    {# Selector de periodos a analizar / comparar. #}
    <div class="card">
        <form method="get" action="{{ path('guardia_stats') }}" class="period-picker">
            <div class="period-picker__groups">
                {% for ay in courses %}
                    <fieldset class="period-group">
                        <legend>{{ ay.schoolYear }}</legend>
                        <label class="choice choice--inline"><input type="checkbox" name="p[]" value="{{ ay.schoolYear }}" {{ ay.schoolYear in selectedTokens ? 'checked' }}> Curso entero</label>
                        {% for t in 1..3 %}
                            {% set tok = ay.schoolYear ~ ':' ~ t %}
                            <label class="choice choice--inline"><input type="checkbox" name="p[]" value="{{ tok }}" {{ tok in selectedTokens ? 'checked' }}> {{ termOrdinals[t] }} trim.</label>
                        {% endfor %}
                    </fieldset>
                {% else %}
                    <p class="muted">No hay cursos definidos todavía.</p>
                {% endfor %}
            </div>
            <div class="period-picker__actions">
                <button type="submit" class="btn">Ver / comparar</button>
            </div>
        </form>
    </div>

    {% set headline = kpis|first %}
    {% set hasBreakdown = byDepartment is not empty or absentRanking is not empty %}
    {% set hasEvolution = evolution.categories|length > 1 %}

    {% if single and headline.absences == 0 %}
        {# Un solo periodo sin ausencias: nada que desglosar, mensaje claro en vez de pestañas vacías. #}
        <div class="card"><div class="empty-state">
            <h2>Sin ausencias en {{ headline.label }}</h2>
            <p>No hay ausencias registradas en este periodo. Prueba con otro curso o trimestre, o marca varios para comparar.</p>
        </div></div>

    {% elseif single %}
        {# ===================== Un solo periodo (repartido en pestañas) ===================== #}
        <div class="tabpanels" data-tabs>
            <nav class="tabs" role="tablist" aria-label="Apartados de estadísticas">
                <button type="button" class="tab is-active" role="tab" id="tab-cobertura" aria-controls="panel-cobertura" aria-selected="true">Cobertura</button>
                <button type="button" class="tab" role="tab" id="tab-evolucion" aria-controls="panel-evolucion" aria-selected="false">Evolución</button>
                <button type="button" class="tab" role="tab" id="tab-equidad" aria-controls="panel-equidad" aria-selected="false">Equidad</button>
                <button type="button" class="tab" role="tab" id="tab-heatmap" aria-controls="panel-heatmap" aria-selected="false">Días y tramos</button>
                {% if hasBreakdown %}<button type="button" class="tab" role="tab" id="tab-desglose" aria-controls="panel-desglose" aria-selected="false">Departamentos y profesores</button>{% endif %}
            </nav>

            <div class="tabpanel" role="tabpanel" id="panel-cobertura" aria-labelledby="tab-cobertura">
                <div class="card progress-hero">
                    <div class="progress-hero__head">
                        <span class="progress-hero__pct">{{ headline.coverageRate }}%</span>
                        <span class="progress-hero__caption">{{ headline.covered }} de {{ headline.absences }} ausencias cubiertas · {{ headline.label }}</span>
                    </div>
                    <div class="progress"><span class="progress__bar" style="width: {{ headline.coverageRate }}%"></span></div>
                </div>
                <div class="worklist-stats worklist-stats--4">
                    <div class="stat"><span class="stat-figure">{{ headline.absences }}</span><span class="stat-label">Ausencias</span></div>
                    <div class="stat stat--success{{ headline.covered == 0 ? ' is-zero' }}"><span class="stat-figure">{{ headline.covered }}</span><span class="stat-label">Cubiertas</span></div>
                    <div class="stat stat--danger{{ headline.incidents == 0 ? ' is-zero' }}"><span class="stat-figure">{{ headline.incidents }}</span><span class="stat-label">Incidencias</span></div>
                    <div class="stat stat--warning{{ headline.unassigned == 0 ? ' is-zero' }}"><span class="stat-figure">{{ headline.unassigned }}</span><span class="stat-label">Sin asignar</span></div>
                </div>
            </div>

            <div class="tabpanel" role="tabpanel" id="panel-evolucion" aria-labelledby="tab-evolucion">
                <div class="card">
                    <div class="page-head"><div><h2>Evolución por mes</h2><p class="lead">Ausencias del periodo, según cómo se resolvieron.</p></div></div>
                    {% if hasEvolution %}<div id="chart-evolution" class="gchart"></div>{{ s.data_table(evolution.table) }}{% else %}<p class="muted">La evolución mensual necesita al menos dos meses con datos.</p>{% endif %}
                </div>
            </div>

            <div class="tabpanel" role="tabpanel" id="panel-equidad" aria-labelledby="tab-equidad">
                <div class="card">
                    <div class="page-head"><div>
                        <h2>Equidad del reparto</h2>
                        <p class="lead">Entre los {{ equity.count }} profesores que han hecho alguna guardia.</p>
                    </div></div>
                    <div class="worklist-stats worklist-stats--4">
                        <div class="stat"><span class="stat-figure">{{ equity.mean }}</span><span class="stat-label">Media</span></div>
                        <div class="stat"><span class="stat-figure">{{ equity.median }}</span><span class="stat-label">Mediana</span></div>
                        <div class="stat"><span class="stat-figure">{{ equity.min }}–{{ equity.max }}</span><span class="stat-label">Mín.–Máx.</span></div>
                        <div class="stat{{ equity.gini < 0.3 ? ' stat--success' : (equity.gini >= 0.45 ? ' stat--danger' : ' stat--warning') }}">
                            <span class="stat-figure" style="font-size: 1.6rem">{{ equity.label }}</span>
                            <span class="stat-label">Índice de equidad (Gini {{ equity.gini }})</span>
                        </div>
                    </div>
                    {% if ranking is not empty %}
                        <table>
                            <thead><tr><th>Profesor</th><th style="width: 55%">Guardias cubiertas</th><th class="mono">Total</th><th class="mono">vs media</th></tr></thead>
                            <tbody>
                                {% for row in ranking %}
                                    {% set diff = (row.total - equity.mean)|round(1) %}
                                    <tr>
                                        <td>{{ row.teacher.fullName }}</td>
                                        <td><div class="load-bar" title="{{ row.total }} guardias cubiertas"><span class="load-bar-fill" style="width: {{ max > 0 ? (row.total * 100 // max) : 0 }}%"></span></div></td>
                                        <td class="mono">{{ row.total }}</td>
                                        <td class="mono {{ diff > 0 ? 'text-success' : (diff < 0 ? 'text-danger' : 'muted') }}">{{ diff > 0 ? '+' }}{{ diff }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                </div>
            </div>

            <div class="tabpanel" role="tabpanel" id="panel-heatmap" aria-labelledby="tab-heatmap">
                <div class="card">
                    <div class="page-head"><div><h2>Ausencias por día y tramo</h2><p class="lead">Dónde se concentra la necesidad de cobertura. Más intenso = más ausencias.</p></div></div>
                    {% if heatmap.slots is not empty %}
                        <div class="heatmap-wrap">
                            <table class="heatmap">
                                <thead><tr>
                                    <th></th>
                                    {% for slot in heatmap.slots %}<th class="mono">{{ s.period_label(slotTimes, slot) }}</th>{% endfor %}
                                    <th class="mono heatmap-total">Total</th>
                                </tr></thead>
                                <tbody>
                                    {% for wd in heatmap.weekdays %}
                                        <tr>
                                            <th>{{ weekdayNames[wd] }}</th>
                                            {% for slot in heatmap.slots %}
                                                {% set n = heatmap.grid[wd][slot] ?? 0 %}
                                                {% set intensity = heatmap.max > 0 ? (n / heatmap.max) : 0 %}
                                                <td class="heat-cell" title="{{ weekdayNames[wd] }} · {{ s.period_label(slotTimes, slot) }} · {{ n }} ausencia(s)"
                                                    style="{% if n > 0 %}background: color-mix(in srgb, var(--accent) {{ (20 + intensity * 80)|round }}%, var(--surface)); color: {{ intensity > 0.55 ? 'var(--on-accent)' : 'var(--text)' }}{% endif %}">
                                                    {{ n > 0 ? n : '' }}
                                                </td>
                                            {% endfor %}
                                            <td class="mono heatmap-total">{{ heatmap.weekdayTotals[wd] ?? 0 }}</td>
                                        </tr>
                                    {% endfor %}
                                    <tr class="heatmap-foot">
                                        <th>Total</th>
                                        {% for slot in heatmap.slots %}<td class="mono">{{ heatmap.slotTotals[slot] ?? 0 }}</td>{% endfor %}
                                        <td class="mono heatmap-total">{{ headline.absences }}</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="muted">Sin horario importado no hay tramos que mostrar.</p>
                    {% endif %}
                </div>
            </div>

            {% if hasBreakdown %}
                <div class="tabpanel" role="tabpanel" id="panel-desglose" aria-labelledby="tab-desglose">
                    {{ s.breakdown(byDepartment, absentRanking, periods) }}
                </div>
            {% endif %}
        </div>

    {% else %}
        {# ===================== Comparativa de varios periodos (en pestañas) ===================== #}
        <div class="tabpanels" data-tabs>
            <nav class="tabs" role="tablist" aria-label="Apartados de estadísticas">
                <button type="button" class="tab is-active" role="tab" id="tab-comparativa" aria-controls="panel-comparativa" aria-selected="true">Comparativa</button>
                <button type="button" class="tab" role="tab" id="tab-evolucion" aria-controls="panel-evolucion" aria-selected="false">Evolución</button>
                {% if hasBreakdown %}<button type="button" class="tab" role="tab" id="tab-desglose" aria-controls="panel-desglose" aria-selected="false">Departamentos y profesores</button>{% endif %}
            </nav>

            <div class="tabpanel" role="tabpanel" id="panel-comparativa" aria-labelledby="tab-comparativa">
                <div class="card">
                    <div class="page-head"><div><h2>Comparativa de cobertura</h2><p class="lead">Ausencias de cada periodo, según cómo se resolvieron.</p></div></div>
                    <div id="chart-comparison" class="gchart"></div>
                </div>
                <div class="card">
                    <div class="page-head"><div><h2>Cobertura y equidad por periodo</h2><p class="lead">Cada fila es uno de los periodos elegidos.</p></div></div>
                    <table>
                        <thead><tr>
                            <th>Periodo</th><th class="mono">Ausencias</th><th class="mono">Cubiertas</th>
                            <th style="width: 20%">Cobertura</th><th class="mono">Incidencias</th><th class="mono">Sin asignar</th>
                            <th class="mono">Media/profe</th><th>Equidad</th>
                        </tr></thead>
                        <tbody>
                            {% for r in kpis %}
                                <tr>
                                    <td>{{ r.label }}</td>
                                    <td class="mono">{{ r.absences }}</td>
                                    <td class="mono">{{ r.covered }}</td>
                                    <td>
                                        <div class="load-bar" title="{{ r.coverageRate }}% cubiertas"><span class="load-bar-fill load-bar-fill--success" style="width: {{ r.coverageRate }}%"></span></div>
                                        <span class="muted mono">{{ r.coverageRate }}%</span>
                                    </td>
                                    <td class="mono {{ r.incidents > 0 ? 'text-danger' }}">{{ r.incidents }}</td>
                                    <td class="mono">{{ r.unassigned }}</td>
                                    <td class="mono">{{ r.mean }}</td>
                                    <td>{{ r.balance }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tabpanel" role="tabpanel" id="panel-evolucion" aria-labelledby="tab-evolucion">
                <div class="card">
                    <div class="page-head"><div><h2>Evolución por mes</h2><p class="lead">Una línea por periodo, alineadas por mes del curso. Elige qué dato comparar.</p></div></div>
                    {% if hasEvolution %}
                        <div class="field field--metric">
                            <label for="evolution-metric">Dato a comparar</label>
                            <select id="evolution-metric">
                                {% for key, name in evolution.metrics %}<option value="{{ key }}" {{ key == evolution.defaultMetric ? 'selected' }}>{{ name }}</option>{% endfor %}
                            </select>
                        </div>
                        <div id="chart-evolution" class="gchart"></div>
                        <div id="evolution-table"></div>
                    {% else %}
                        <p class="muted">La evolución necesita al menos dos meses con datos en los periodos elegidos.</p>
                    {% endif %}
                </div>
            </div>

            {% if hasBreakdown %}
                <div class="tabpanel" role="tabpanel" id="panel-desglose" aria-labelledby="tab-desglose">
                    {{ s.breakdown(byDepartment, absentRanking, periods) }}
                </div>
            {% endif %}
        </div>
    {% endif %}

    {# Datos para los gráficos (los lee guardia-charts.js). Los mismos números que las tablas. #}
    <script type="application/json" id="guardia-evolution-data">{{ evolution|json_encode|raw }}</script>
    {% if not single %}<script type="application/json" id="guardia-kpis-data">{{ kpis|json_encode|raw }}</script>{% endif %}
{% endblock %}

{% block page_scripts %}
    <script src="{{ asset_ver('/vendor/apexcharts/apexcharts.min.js') }}"></script>
    {# guardia-charts antes de tabs: los gráficos se renderizan con los paneles aún visibles (miden bien)
       y tabs.js oculta después los inactivos; al reabrir una pestaña, tabs.js dispara resize. #}
    <script src="{{ asset_ver('/js/guardia-charts.js') }}"></script>
    <script src="{{ asset_ver('/js/tabs.js') }}"></script>
{% endblock %}
