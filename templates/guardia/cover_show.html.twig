{% extends 'app_shell.html.twig' %}

{% block title %}Guardia · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('guardia_mine') }}">Mis guardias</a><span class="sep">/</span>Guardia{% endblock %}

{# Pantalla empujada. #}
{% block bottomnav %}{% endblock %}

{% block body %}
    {% set times = slotTimes[cover.slotIndex] ?? null %}
    {% set done = cover.notCovered %}

    <div class="backbar">
        <a class="backbar__back" href="{{ path('guardia_mine') }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 5l-7 7 7 7"/></svg>Mis guardias</a>
        {% if canEdit %}<a class="backbar__edit" href="{{ path('guardia_cover_edit', { id: cover.id }) }}">Modificar</a>{% endif %}
    </div>

    <div class="task-detail">
        {% if done %}
            {# Incidencia registrada: cabecera clara, sin hero verde. #}
            <div class="guardia-detail-head is-incident">
                <div class="guardia-detail-head__top">
                    <span class="guardia-detail-head__flag"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 9v4M12 17h.01"/><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0z"/></svg>Incidencia</span>
                    <span class="guardia-detail-head__time">{% if times %}{{ times.startsAt|date('H:i', false) }}–{{ times.endsAt|date('H:i', false) }}{% else %}{{ cover.slotIndex + 1 }}ª hora{% endif %}</span>
                </div>
                <div class="guardia-detail-head__where guardia-detail-head__where--dark">{{ cover.roomName ?: 'Aula' }} · {{ cover.groupName ?: 'Grupo' }}</div>
                <div class="guardia-detail-head__sub guardia-detail-head__sub--dark">Debías cubrir a <strong>{{ cover.absentTeacher.fullName }}</strong></div>
            </div>
        {% else %}
            <div class="guardia-detail-head">
                <div class="guardia-detail-head__top">
                    <span class="guardia-detail-head__eyebrow"><span class="guardia-hero__pulse"></span>Tu guardia</span>
                    <span class="guardia-detail-head__time">{% if times %}{{ times.startsAt|date('H:i', false) }}–{{ times.endsAt|date('H:i', false) }}{% else %}{{ cover.slotIndex + 1 }}ª hora{% endif %}</span>
                </div>
                <div class="guardia-detail-head__where">{{ cover.roomName ?: 'Aula' }} · {{ cover.groupName ?: 'Grupo' }}</div>
                <div class="guardia-detail-head__sub">Cubres a <strong>{{ cover.absentTeacher.fullName }}</strong></div>
            </div>
        {% endif %}

        <div class="detail-block">
            <div class="detail-block__label">Tarea para el grupo{% if cover.taskNote %} <span class="task-note-flag">tiene tarea</span>{% endif %}</div>
            {% if cover.taskNote %}
                <div class="guardia-tasknote"><p class="detail-prose">{{ cover.taskNote|nl2br }}</p></div>
            {% else %}
                <div class="guardia-empty">
                    <span class="guardia-empty__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3v5h5"/><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/></svg></span>
                    <div class="guardia-empty__title">El profesor no ha dejado tarea</div>
                    <p class="guardia-empty__sub">Mantén al grupo con trabajo de repaso o estudio de su materia.</p>
                </div>
            {% endif %}
        </div>

        <div class="detail-block">
            <div class="detail-block__label">La clase</div>
            <dl class="meta-grid">
                <div class="meta-grid__cell"><dt>Grupo</dt><dd>{{ cover.groupName ?: '—' }}</dd></div>
                <div class="meta-grid__cell"><dt>Aula</dt><dd>{{ cover.roomName ?: '—' }}</dd></div>
            </dl>
        </div>
    </div>
{% endblock %}
