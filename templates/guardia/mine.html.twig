{% extends 'app_shell.html.twig' %}

{% block title %}Mis guardias{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Mis guardias{% endblock %}

{# Cuenta atrás legible ("en 40 min" / "en 2 h 10 min") reutilizada por el protagonista y la fila
   destacada, para no repetir el formateo. #}
{% macro countdown(min) %}{% if min < 60 %}en {{ min }} min{% else %}en {{ min // 60 }} h{% if min % 60 %} {{ min % 60 }} min{% endif %}{% endif %}{% endmacro %}

{% block body %}
    {% import _self as fmt %}
    {% set weekdayNames = {1: 'Lunes', 2: 'Martes', 3: 'Miércoles', 4: 'Jueves', 5: 'Viernes', 6: 'Sábado', 7: 'Domingo'} %}
    {% set nextItem = today.next is not null ? today.items[today.next] : null %}
    {% set todayLabel = weekdayNames['now'|date('N', false)] ~ ' ' ~ 'now'|date('d/m', false) %}

    <div class="page-head page-head--ruled">
        <div>
            {% if today.items is not empty %}<div class="page-eyebrow mono g-narrow">{{ todayLabel }}</div>{% endif %}
            <h1>Mis guardias</h1>
            <p class="lead g-wide">Tus guardias de hoy y las que vienen. Pulsa una para ver el detalle y la tarea del grupo.</p>
        </div>
        <div class="page-head__actions">
            <a class="btn secondary" href="{{ path('guardia_mine_history') }}">Ver histórico</a>
            <a class="btn" href="{{ path('guardia_absence_new', { teacher: app.user.id }) }}">Voy a faltar…</a>
        </div>
    </div>

    {% if today.items is empty %}
        {# ESTADO VACÍO — mensaje positivo + la siguiente guardia prevista (si la hay). #}
        <section class="card guardia-empty">
            <div class="guardia-empty__badge" aria-hidden="true">✓</div>
            <h2>Hoy no te toca guardia</h2>
            <p>Estás libre de guardias. Te avisaremos en cuanto se te asigne una nueva.</p>

            {% set nextDay = upcoming|first %}
            {% if nextDay %}
                {% set sc = nextDay.covers|first %}
                {% set st = slotTimes[sc.slotIndex] ?? null %}
                <div class="next-preview">
                    <div class="next-preview__title mono">Siguiente prevista</div>
                    <div class="next-preview__row">
                        <span class="next-preview__time mono">
                            <strong>{% if st %}{{ st.startsAt|date('H:i', false) }}{% else %}{{ sc.slotIndex + 1 }}ª{% endif %}</strong>
                            <span>{% if nextDay.isTomorrow %}mañana{% else %}{{ nextDay.date|date('d/m', false) }}{% endif %}</span>
                        </span>
                        <span class="next-preview__place">
                            <span class="next-preview__where">{{ [sc.groupName, sc.roomName]|filter(v => v)|join(' · ') ?: 'Sin especificar' }}</span>
                            <span class="next-preview__teacher">Cubres a {{ sc.absentTeacher.fullName }}</span>
                        </span>
                        {% if sc.taskNote %}<span class="badge badge--warning" data-tone="warning">Tarea</span>{% endif %}
                    </div>
                </div>
                <a class="btn" href="#proximas">Ver próximas guardias</a>
            {% endif %}
        </section>

        {# Sin guardias hoy: no hay rejilla, así que Próximas va a ancho completo. #}
        {{ include('guardia/_upcoming.html.twig') }}
    {% else %}
        {# HOY — protagonista a la derecha (arriba en móvil), el resto del día a la izquierda. #}
        {# restCount = guardias del día que NO son la próxima; si es 0, en móvil (donde la próxima
           solo vive en el protagonista) la columna del "resto" se queda vacía y se oculta. #}
        {% set restCount = today.counts.assigned - (nextItem ? 1 : 0) %}
        <div class="today-guardias">
            <div class="today-guardias__main{{ restCount == 0 ? ' is-only-next' }}">
                <div class="today__head">
                    <h2 class="today__title"><span class="g-wide">Hoy</span><span class="g-narrow">Resto de hoy</span></h2>
                    <span class="today__date mono g-wide">{{ todayLabel }}</span>
                    {% if today.counts.pending > 0 %}
                        <span class="count-chip">{{ today.counts.pending }} pendiente{{ today.counts.pending != 1 ? 's' }}</span>
                    {% endif %}
                </div>

                <div class="today-list">
                    {% for i, item in today.items %}
                        {% set cover = item.cover %}
                        {% set isNext = i == today.next %}
                        <a class="today-row{{ isNext ? ' is-next' }}{{ item.done ? ' is-done' }}{{ cover.notCovered ? ' is-incident' }}" href="{{ path('guardia_cover_show', { id: cover.id }) }}">
                            <span class="today-row__slot mono">
                                <strong>{% if item.startsAt %}{{ item.startsAt|date('H:i', false) }}{% else %}{{ cover.slotIndex + 1 }}ª{% endif %}</strong>
                                <span>{% if item.endsAt %}{{ item.endsAt|date('H:i', false) }}{% else %}hora{% endif %}</span>
                            </span>
                            <span class="today-row__place">
                                {% if isNext %}<span class="today-row__eyebrow mono">Próxima{% if item.minutesUntil is not null %} · {{ fmt.countdown(item.minutesUntil) }}{% endif %}</span>{% endif %}
                                <span class="today-row__where">{{ [cover.roomName, cover.groupName]|filter(v => v)|join(' · ') ?: 'Sin especificar' }}</span>
                                <span class="today-row__teacher">{% if item.done %}Cubriste{% else %}Cubres{% endif %} a {% if isNext %}<strong>{{ cover.absentTeacher.fullName }}</strong>{% else %}{{ cover.absentTeacher.fullName }}{% endif %}</span>
                            </span>
                            {% if cover.notCovered %}<span class="badge badge--danger" data-tone="danger">Incidencia</span>
                            {% elseif item.done %}<span class="today-row__done mono">✓ Hecha</span>
                            {% elseif cover.taskNote %}<span class="badge badge--warning" data-tone="warning">Tiene tarea</span>
                            {% else %}<span class="today-row__notask mono">Sin tarea</span>{% endif %}
                            {% if item.done %}<span></span>{% else %}<span class="today-row__go" aria-hidden="true">›</span>{% endif %}
                        </a>
                    {% endfor %}
                </div>

                {# Próximas dentro de la columna de "Hoy": mismo ancho que las filas del día. #}
                {{ include('guardia/_upcoming.html.twig') }}
            </div>

            <aside class="today-guardias__aside">
                {% if nextItem %}
                    {% set cover = nextItem.cover %}
                    <a class="hero-guardia{{ cover.notCovered ? ' is-incident' }}" href="{{ path('guardia_cover_show', { id: cover.id }) }}">
                        <span class="hero-guardia__eyebrow"><span class="pulse-dot" aria-hidden="true"></span>Tu próxima guardia</span>
                        <span class="hero-guardia__timerow">
                            <span class="hero-guardia__time mono">{% if nextItem.startsAt %}{{ nextItem.startsAt|date('H:i', false) }}{% else %}{{ cover.slotIndex + 1 }}ª{% endif %}</span>
                            {% if nextItem.minutesUntil is not null %}<span class="hero-guardia__countdown mono">{{ fmt.countdown(nextItem.minutesUntil) }}</span>{% endif %}
                        </span>
                        {% if nextItem.endsAt %}<span class="hero-guardia__ends mono">termina {{ nextItem.endsAt|date('H:i', false) }}</span>{% endif %}
                        <span class="hero-guardia__sep" aria-hidden="true"></span>
                        <span class="hero-guardia__place">{{ [cover.roomName, cover.groupName]|filter(v => v)|join(' · ') ?: 'Sin especificar' }}</span>
                        <span class="hero-guardia__teacher">Cubres a <strong>{{ cover.absentTeacher.fullName }}</strong></span>
                        {% if cover.notCovered %}<span class="hero-guardia__badge hero-guardia__badge--danger">Incidencia</span>
                        {% elseif cover.taskNote %}<span class="hero-guardia__badge hero-guardia__badge--task">Tiene tarea</span>{% endif %}
                        <span class="hero-guardia__cta">Ver detalle y tarea del grupo →</span>
                    </a>
                {% endif %}

                <div class="today-summary">
                    <div class="today-summary__title mono">Resumen de hoy</div>
                    <div class="today-summary__row"><span>Guardias asignadas</span><span class="mono">{{ today.counts.assigned }}</span></div>
                    <div class="today-summary__row"><span>Pendientes</span><span class="mono today-summary__pending">{{ today.counts.pending }}</span></div>
                    <div class="today-summary__row"><span>Con tarea</span><span class="mono today-summary__task">{{ today.counts.withTask }}</span></div>
                </div>
            </aside>
        </div>
    {% endif %}
{% endblock %}
