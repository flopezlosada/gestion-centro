{% extends 'app_shell.html.twig' %}

{% block title %}Mis guardias{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Mis guardias{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Mis guardias</h1>
            <p class="lead">Las guardias que tienes asignadas de hoy en adelante. Pulsa una para ver el detalle y la tarea del grupo.</p>
        </div>
        <a class="btn" href="{{ path('guardia_absence_new', { teacher: app.user.id }) }}">Voy a faltar…</a>
    </div>

    {# Contador personal del curso, con la media del claustro como referencia de reparto justo. #}
    <div class="worklist-stats worklist-stats--2">
        <div class="stat stat--success{{ myCovered == 0 ? ' is-zero' }}">
            <span class="stat-figure">{{ myCovered }}</span><span class="stat-label">Mis guardias este curso</span>
        </div>
        <div class="stat{{ staffAverage == 0 ? ' is-zero' }}">
            <span class="stat-figure">{{ staffAverage }}</span><span class="stat-label">Media del claustro</span>
        </div>
    </div>

    <div class="card">
        {% if covers is empty %}
            <div class="empty-state">
                <h2>No tienes guardias asignadas</h2>
                <p>Cuando se te asigne una guardia para cubrir una ausencia, aparecerá aquí (hoy y días siguientes).</p>
            </div>
        {% else %}
            {% set todayStr = today|date('Y-m-d', false) %}
            {% set tomorrowStr = today|date_modify('+1 day')|date('Y-m-d', false) %}
            <table>
                <thead>
                    <tr><th>Hora</th><th>Grupo</th><th>Aula</th><th>Profesor ausente</th><th></th></tr>
                </thead>
                <tbody>
                    {% set lastDay = null %}
                    {% for cover in covers %}
                        {% set dayStr = cover.date|date('Y-m-d', false) %}
                        {% if dayStr != lastDay %}
                            {% set lastDay = dayStr %}
                            <tr class="daygroup{{ dayStr == todayStr ? ' daygroup--today' }}">
                                <th colspan="5">
                                    {% if dayStr == todayStr %}<span class="badge badge--ok" data-tone="success">Hoy</span>
                                    {% elseif dayStr == tomorrowStr %}<span class="badge" data-tone="muted">Mañana</span>{% endif %}
                                    <span class="mono {{ dayStr == todayStr ? '' : 'muted' }}">{{ cover.date|date('d/m/Y', false) }}</span>
                                </th>
                            </tr>
                        {% endif %}
                        <tr class="{{ cover.notCovered ? 'is-not-covered' }}">
                            <td class="mono">{% set times = slotTimes[cover.slotIndex] ?? null %}{% if times %}{{ times.startsAt|date('H:i', false) }}–{{ times.endsAt|date('H:i', false) }}{% else %}{{ cover.slotIndex + 1 }}ª{% endif %}</td>
                            <td><a href="{{ path('guardia_cover_show', { id: cover.id }) }}">{{ cover.groupName ?? '—' }}</a></td>
                            <td class="mono">{{ cover.roomName ?? '—' }}</td>
                            <td>{{ cover.absentTeacher.fullName }}</td>
                            <td><a class="link-action" href="{{ path('guardia_cover_show', { id: cover.id }) }}">Ver</a></td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
