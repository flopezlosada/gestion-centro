{% extends 'app_shell.html.twig' %}

{% block title %}Histórico de guardias{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('guardia_index') }}">Guardias</a><span class="sep">/</span>Histórico{% endblock %}

{% block body %}
    {# La pantalla "modificar" (detalle completo + registro de auditoría) exige permiso de escritura; el
       histórico solo lectura. Solo enlazamos si el usuario puede editar, para no llevar a un 403. #}
    {% set canEdit = is_granted(constant('App\\Security\\Voter\\AreaVoter::WRITE'), constant('App\\Enum\\Area::GUARDIAS')) %}
    <div class="page-head">
        <div>
            <h1>Histórico de guardias</h1>
            <p class="lead">Qué profesor cubrió cada grupo y cuándo. Busca, filtra por columna u ordena pulsando la cabecera.</p>
            {% if years|length > 1 %}
                <nav class="year-nav" aria-label="Curso">
                    {% for y in years %}
                        <a href="{{ path('guardia_history', { curso: y }) }}" class="year-nav__item{{ y == curso ? ' is-active' }}"{{ y == curso ? ' aria-current=page' }}>{{ y }}</a>
                    {% endfor %}
                </nav>
            {% endif %}
        </div>
    </div>

    <div class="card">
        {% if covers is empty %}
            <div class="empty-state">
                <h2>Sin guardias registradas en {{ curso }}</h2>
                <p>Cuando se registren ausencias y se repartan guardias en este curso, aparecerán aquí.</p>
            </div>
        {% else %}
            <table data-list-tools>
                <thead>
                    <tr>
                        <th data-filter-range="Fecha">Fecha</th>
                        <th data-filter="Tramo">Tramo</th>
                        <th data-filter="Grupo">Grupo</th>
                        <th>Aula</th>
                        <th data-filter="Ausente">Profesor ausente</th>
                        <th data-filter="Guardia">Guardia</th>
                        <th data-filter="Estado">Estado</th>
                        {% if canEdit %}<th></th>{% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for cover in covers %}
                        {% set times = slotTimes[cover.slotIndex] ?? null %}
                        <tr class="{{ cover.notCovered ? 'is-not-covered' }}">
                            <td>{{ cover.date|date('d/m/Y', false) }}</td>
                            <td data-sort="{{ cover.slotIndex }}">{% if times %}{{ times.startsAt|date('H:i', false) }}–{{ times.endsAt|date('H:i', false) }}{% else %}{{ cover.slotIndex + 1 }}ª{% endif %}</td>
                            <td>{{ cover.groupName ?? '—' }}</td>
                            <td class="mono">{{ cover.roomName ?? '—' }}</td>
                            <td>{{ cover.absentTeacher.fullName }}</td>
                            <td>{{ cover.assignedGuardia ? cover.assignedGuardia.fullName : '—' }}</td>
                            <td>
                                {% if cover.notCovered %}<span class="badge badge--danger" data-tone="danger">Incidencia</span>
                                {% elseif cover.assignedGuardia %}<span class="badge badge--ok" data-tone="success">Cubierta</span>
                                {% else %}<span class="badge badge--muted" data-tone="muted">Sin asignar</span>{% endif %}
                            </td>
                            {% if canEdit %}<td><a href="{{ path('guardia_cover_edit', { id: cover.id }) }}">Ver / editar</a></td>{% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
