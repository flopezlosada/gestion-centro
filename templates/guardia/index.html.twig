{% extends 'app_shell.html.twig' %}

{% set ck = constant('App\\Enum\\ScheduleActivityKind::COLLABORATOR') %}

{% block title %}Parte de guardias{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Parte de guardias{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Parte de guardias</h1>
            <p class="lead">Ausencias de {{ weekday.label|lower }} {{ date|date('d/m/Y', false) }} y reparto de las guardias que las cubren.</p>
        </div>
        <form method="get" action="{{ path('guardia_index') }}" class="inline-form">
            <a class="btn btn--ghost" href="{{ path('guardia_index', { date: date|date_modify('-1 day')|date('Y-m-d', false), slot: slotIndex }) }}">‹ Día anterior</a>
            <input type="date" name="date" value="{{ date|date('Y-m-d', false) }}">
            <input type="hidden" name="slot" value="{{ slotIndex }}">
            <button type="submit" class="btn">Ir</button>
            <a class="btn btn--ghost" href="{{ path('guardia_index', { date: date|date_modify('+1 day')|date('Y-m-d', false), slot: slotIndex }) }}">Día siguiente ›</a>
        </form>
    </div>

    {% if slots is empty %}
        <div class="card">
            <div class="empty-state">
                <h2>No hay horario importado para el curso {{ schoolYear }}</h2>
                <p>Importa el horario de Peñalara de este curso para poder registrar ausencias y repartir guardias.</p>
                {% if is_granted(constant('App\\Security\\Voter\\AreaVoter::WRITE'), constant('App\\Enum\\Area::ADMINISTRATION')) %}
                    <p><a class="btn" href="{{ path('admin_timetable_import') }}">Importar horario</a></p>
                {% endif %}
            </div>
        </div>
    {% else %}
        {# Pestañas de tramo horario #}
        <nav class="tabs" aria-label="Tramo horario">
            {% for slot in slots %}
                <a class="tab {{ slot.index == slotIndex ? 'is-active' }}"
                   href="{{ path('guardia_index', { date: date|date('Y-m-d', false), slot: slot.index }) }}">
                    {{ slot.startsAt|date('H:i', false) }}–{{ slot.endsAt|date('H:i', false) }}
                </a>
            {% endfor %}
        </nav>

        {# Tabla del parte #}
        <div class="card">
            <div class="page-head"><div><h2>Ausencias de esta hora</h2></div>
                <div class="inline-form">
                    <a class="btn" href="{{ path('guardia_absence_new', { date: date|date('Y-m-d', false) }) }}">+ Apuntar ausencia</a>
                    <form method="post" action="{{ path('guardia_auto_assign') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('guardia_auto_assign') }}">
                        <input type="hidden" name="date" value="{{ date|date('Y-m-d', false) }}">
                        <input type="hidden" name="slot" value="{{ slotIndex }}">
                        <button type="submit" class="btn btn--ghost">Repartir guardias</button>
                    </form>
                </div>
            </div>

            {% if covers is empty %}
                <p class="muted">No hay ausencias registradas en esta hora.</p>
            {% else %}
                <table>
                    <thead>
                        <tr><th>Grupo · Aula</th><th>Profesor ausente</th><th>Tarea</th><th>Guardia asignada</th><th></th></tr>
                    </thead>
                    <tbody>
                        {% for cover in covers %}
                            <tr class="{{ cover.notCovered ? 'is-not-covered' }}">
                                <td>
                                    <strong>{{ cover.groupName ?? '—' }}</strong>
                                    {% if cover.roomName %}<span class="muted mono"> · {{ cover.roomName }}</span>{% endif %}
                                </td>
                                <td>{{ cover.absentTeacher.fullName }}</td>
                                <td>
                                    {% if cover.taskNote %}
                                        <span class="task-note" title="{{ cover.taskNote }}" aria-label="Tarea: {{ cover.taskNote }}">✉</span>
                                    {% else %}<span class="muted">—</span>{% endif %}
                                </td>
                                <td>
                                    <form method="post" action="{{ path('guardia_reassign', { id: cover.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('guardia_reassign' ~ cover.id) }}">
                                        <select name="guardia" onchange="this.form.submit()">
                                            <option value="">— sin asignar —</option>
                                            {% for entry in pool %}
                                                <option value="{{ entry.teacher.id }}" {{ cover.assignedGuardia and cover.assignedGuardia.id == entry.teacher.id ? 'selected' }}>
                                                    {{ entry.teacher.fullName }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                        <noscript><button type="submit">Guardar</button></noscript>
                                    </form>
                                </td>
                                <td class="row-actions">
                                    <form method="post" action="{{ path('guardia_incident', { id: cover.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('guardia_incident' ~ cover.id) }}">
                                        <button type="submit" class="{{ cover.notCovered ? 'badge badge--danger' : 'link' }}" title="Marca que la guardia no se cubrió (no cuenta para el reparto)">
                                            {{ cover.notCovered ? '⚠ No se cubrió' : 'Incidencia' }}
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('guardia_delete', { id: cover.id }) }}" data-confirm="¿Borrar la ausencia de {{ cover.absentTeacher.fullName }}?">
                                        <input type="hidden" name="_token" value="{{ csrf_token('guardia_delete' ~ cover.id) }}">
                                        <button type="submit" class="link-danger">Borrar</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>

        {# Panel de profesores de guardia a esta hora: quién puede cubrir y cómo va el reparto #}
        <div class="card">
            <div class="page-head"><div><h2>Profesores de guardia a esta hora</h2></div></div>
            {% if pool is empty %}
                <p class="muted">Nadie tiene guardia en el horario para este tramo.</p>
            {% else %}
                <p class="muted">El número es cuántas guardias lleva cada uno en este tramo (el reparto elige primero al que menos tiene).</p>
                <div class="card-grid">
                    {% for entry in pool %}
                        {% set tid = entry.teacher.id %}
                        {% set absent = tid in absentIds %}
                        {% set coveringGroup = assignedHere[tid] ?? null %}
                        {% set state = absent ? 'is-absent' : (coveringGroup ? 'is-busy' : 'is-free') %}
                        <div class="mini-card {{ state }}">
                            <div class="mini-card-head">
                                <strong>{{ entry.teacher.fullName }}</strong>
                                {% if entry.kind == ck %}<span class="badge badge--ok" title="Colaborador (solo si faltan guardias)">C</span>{% endif %}
                            </div>
                            <div class="mini-card-status">
                                {% if absent %}
                                    <span class="badge badge--danger">Ausente</span>
                                {% elseif coveringGroup %}
                                    <span class="badge badge--muted">→ {{ coveringGroup }}</span>
                                {% else %}
                                    <span class="badge badge--ok">Disponible</span>
                                {% endif %}
                                <span class="load-count">{{ slotLoad[tid] ?? 0 }}</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
