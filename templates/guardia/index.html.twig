{% extends 'app_shell.html.twig' %}

{% set ck = constant('App\\Enum\\ScheduleActivityKind::COLLABORATOR') %}

{% block title %}Parte de guardias{% endblock %}

{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Parte de guardias{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Parte de guardias</h1>
            <p class="lead">Ausencias de {{ weekday.label|lower }} {{ date|date('d/m/Y', false) }} y reparto de las guardias que las cubren.</p>
        </div>
        <div class="day-nav">
            <a class="day-nav-arrow" href="{{ path('guardia_index', { date: date|date_modify('-1 day')|date('Y-m-d', false), slot: slotIndex }) }}" aria-label="Día anterior">‹</a>
            <form method="get" action="{{ path('guardia_index') }}" class="day-nav-date">
                <input type="date" name="date" value="{{ date|date('Y-m-d', false) }}" onchange="this.form.submit()" aria-label="Fecha del parte">
                <input type="hidden" name="slot" value="{{ slotIndex }}">
                <noscript><button type="submit" class="btn">Ir</button></noscript>
            </form>
            <a class="day-nav-arrow" href="{{ path('guardia_index', { date: date|date_modify('+1 day')|date('Y-m-d', false), slot: slotIndex }) }}" aria-label="Día siguiente">›</a>
            <a class="btn btn--ghost" href="{{ path('guardia_index', { slot: slotIndex }) }}">Hoy</a>
        </div>
    </div>

    {% if slots is empty %}
        <div class="card">
            <div class="empty-state">
                <h2>No hay horario importado para el curso {{ schoolYear }}</h2>
                <p>Importa el horario de Peñalara de este curso para poder registrar ausencias y repartir guardias.</p>
                {% if is_granted(constant('App\\Security\\Voter\\AreaVoter::WRITE'), constant('App\\Enum\\Area::ADMINISTRATION')) %}
                    <p><a class="btn" href="{{ path('admin_timetable_import') }}">Importar horario</a></p>
                {% endif %}
            </div>
        </div>
    {% else %}
        {# Pestañas de tramo horario #}
        <nav class="tabs" aria-label="Tramo horario">
            {% for slot in slots %}
                <a class="tab {{ slot.index == slotIndex ? 'is-active' }}"
                   href="{{ path('guardia_index', { date: date|date('Y-m-d', false), slot: slot.index }) }}">
                    {{ slot.startsAt|date('H:i', false) }}–{{ slot.endsAt|date('H:i', false) }}
                </a>
            {% endfor %}
        </nav>

        {# Tabla del parte #}
        <div class="card">
            <div class="page-head"><div><h2>Ausencias de esta hora</h2></div>
                <div class="page-head-actions">
                    <a class="btn" href="{{ path('guardia_absence_new', { date: date|date('Y-m-d', false) }) }}">+ Apuntar ausencia</a>
                    <form method="post" action="{{ path('guardia_auto_assign') }}" class="inline-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('guardia_auto_assign') }}">
                        <input type="hidden" name="date" value="{{ date|date('Y-m-d', false) }}">
                        <input type="hidden" name="slot" value="{{ slotIndex }}">
                        <button type="submit" class="btn secondary" title="Vuelve a repartir las guardias pendientes de asignar de este tramo">↻ Repartir guardias</button>
                    </form>
                </div>
            </div>

            {% if covers is empty %}
                <p class="muted">No hay ausencias registradas en esta hora.</p>
            {% else %}
                <table>
                    <thead>
                        <tr><th>Grupo · Aula</th><th>Profesor ausente</th><th>Tarea para el grupo</th><th>Guardia asignada</th><th></th></tr>
                    </thead>
                    <tbody>
                        {% for cover in covers %}
                            <tr class="{{ cover.notCovered ? 'is-not-covered' }}">
                                <td>
                                    <strong>{{ cover.groupName ?? '—' }}</strong>
                                    {% if cover.roomName %}<span class="muted mono"> · {{ cover.roomName }}</span>{% endif %}
                                </td>
                                <td>{{ cover.absentTeacher.fullName }}</td>
                                <td class="task-cell">
                                    {% if cover.taskNote %}
                                        <span title="{{ cover.taskNote }}">{{ cover.taskNote|length > 60 ? cover.taskNote|slice(0, 60) ~ '…' : cover.taskNote }}</span>
                                    {% else %}<span class="muted">Sin tarea</span>{% endif %}
                                </td>
                                <td>
                                    {% if cover.notCovered %}
                                        <span class="badge badge--danger">No se cubrió</span>
                                        {% if cover.assignedGuardia %}<span class="muted"> · {{ cover.assignedGuardia.fullName }}</span>{% endif %}
                                    {% elseif cover.assignedGuardia %}
                                        {{ cover.assignedGuardia.fullName }}
                                    {% else %}
                                        <span class="badge badge--muted">Sin asignar</span>
                                    {% endif %}
                                </td>
                                <td class="row-actions">
                                    <a class="link-action" href="{{ path('guardia_cover_edit', { id: cover.id }) }}">Modificar</a>
                                    <form method="post" action="{{ path('guardia_delete', { id: cover.id }) }}" data-confirm="¿Borrar la ausencia de {{ cover.absentTeacher.fullName }} en {{ cover.groupName ?? 'este grupo' }}? Esta línea del parte desaparecerá.">
                                        <input type="hidden" name="_token" value="{{ csrf_token('guardia_delete' ~ cover.id) }}">
                                        <button type="submit" class="link-danger">Borrar</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>

        {# Panel de profesores de guardia a esta hora: quién puede cubrir y cómo va el reparto #}
        <div class="card">
            <div class="page-head"><div>
                <h2>Profesores de guardia a esta hora</h2>
                <p class="lead">Quién tiene guardia en este tramo según el horario, para poder cubrir las ausencias de arriba.</p>
            </div></div>
            {% if pool is empty %}
                <p class="muted">Nadie tiene guardia en el horario para este tramo.</p>
            {% else %}
                <ul class="pool-legend" aria-label="Leyenda">
                    <li><span class="badge badge--ok">Disponible</span> libre para cubrir</li>
                    <li><span class="badge badge--muted">→ grupo</span> ya está cubriendo ese grupo</li>
                    <li><span class="badge badge--danger">Ausente</span> hoy también falta, no puede cubrir</li>
                    <li><span class="load-count">n</span> guardias que ya lleva en este tramo (se asigna primero al que menos tiene)</li>
                </ul>
                <div class="card-grid">
                    {% for entry in pool %}
                        {% set tid = entry.teacher.id %}
                        {% set absent = tid in absentIds %}
                        {% set coveringGroup = assignedHere[tid] ?? null %}
                        {% set state = absent ? 'is-absent' : (coveringGroup ? 'is-busy' : 'is-free') %}
                        <div class="mini-card {{ state }}">
                            <div class="mini-card-head">
                                <strong>{{ entry.teacher.fullName }}</strong>
                                {% if entry.kind == ck %}<span class="badge badge--ok" title="Colaborador: solo entra si no llegan los profesores de guardia">Colaborador</span>{% endif %}
                            </div>
                            <div class="mini-card-status">
                                {% if absent %}
                                    <span class="badge badge--danger">Ausente</span>
                                {% elseif coveringGroup %}
                                    <span class="badge badge--muted">→ {{ coveringGroup }}</span>
                                {% else %}
                                    <span class="badge badge--ok">Disponible</span>
                                {% endif %}
                                <span class="load-count" title="{{ slotLoad[tid] ?? 0 }} guardia(s) en este tramo. El reparto elige primero al que menos tiene.">{{ slotLoad[tid] ?? 0 }}</span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
