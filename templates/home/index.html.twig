{% extends 'app_shell.html.twig' %}

{% block title %}Inicio · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}Inicio{% endblock %}

{% block body %}
    {% set dias = ['', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo'] %}
    {% set nombre = app.user.fullName|trim|split(' ')|first %}
    {% set iniciales = app.user.fullName|split(' ')|map(w => w|first)|join|slice(0, 2)|upper %}
    {% set hoyStr = now|date('Y-m-d') %}

    <div class="home">
        {# ---- Cabecera: fecha + saludo + avatar ---- #}
        <header class="home-head">
            <div>
                <p class="eyebrow">{{ dias[now|date('N')] }} {{ now|date('d/m') }}</p>
                <h1 class="home-greeting">Buenos días, {{ nombre }}</h1>
                {% if roleSubtitle %}<p class="home-role">{{ roleSubtitle }}</p>{% endif %}
            </div>
            <span class="home-avatar" aria-hidden="true">{{ iniciales }}</span>
        </header>

        {# ---- Ancla: próxima guardia (hero) o tira "sin guardia" ---- #}
        {% if nextGuardia %}
            {% set g = nextGuardia.cover %}
            <a class="guardia-hero" href="{{ path('guardia_mine') }}">
                <div class="guardia-hero__top">
                    <span class="guardia-hero__eyebrow"><span class="guardia-hero__pulse"></span>Tu próxima guardia</span>
                    {% if nextGuardia.minutesUntil is not null %}<span class="guardia-hero__in">en {{ nextGuardia.minutesUntil }} min</span>{% endif %}
                </div>
                <div class="guardia-hero__line">
                    {% if nextGuardia.startsAt %}<span class="guardia-hero__time">{{ nextGuardia.startsAt|date('H:i') }}</span>{% endif %}
                    <span class="guardia-hero__where">{{ g.roomName ?: 'Aula por asignar' }}{% if g.groupName %} · {{ g.groupName }}{% endif %}</span>
                </div>
                <div class="guardia-hero__sub">Cubres a {{ g.absentTeacher.fullName }} · {% if g.taskNote %}<span class="guardia-hero__task">tiene tarea</span>{% else %}<span class="guardia-hero__notask">sin tarea</span>{% endif %}</div>
            </a>
        {% else %}
            <a class="no-guardia" href="{{ path('guardia_mine') }}">
                <span class="no-guardia__icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                </span>
                <span class="no-guardia__body">
                    <span class="no-guardia__title">Hoy no tienes guardia</span>
                    {% if upcomingGuardia %}<span class="no-guardia__meta">Próxima: {{ dias[upcomingGuardia.cover.date|date('N')] }} {{ upcomingGuardia.cover.date|date('d/m') }}{% if upcomingGuardia.startsAt %} · {{ upcomingGuardia.startsAt|date('H:i') }}{% endif %}</span>{% endif %}
                </span>
                <span class="no-guardia__cta">Ver</span>
            </a>
        {% endif %}

        {# ---- Mis tareas (lista abierta; vencidas resaltadas) ---- #}
        <section class="home-section">
            <div class="home-section__head">
                <span class="eyebrow">Mis tareas</span>
                <a class="home-section__more" href="{{ path('task_index') }}">Ver todas</a>
            </div>

            {% if myTasks is empty %}
                <p class="home-empty">No tienes tareas pendientes para hoy. 👌</p>
            {% else %}
                <ul class="tasklist">
                    {% for entry in myTasks %}
                        {% set t = entry.task %}
                        {% set overdue = t.dueDate|date('Y-m-d') < hoyStr %}
                        <li class="tasklist__item{{ overdue ? ' is-overdue' }}">
                            {% if t.requiresCheckbox %}
                                <form method="post" action="{{ path('task_toggle_done', { id: t.id }) }}" class="tasklist__check-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle_done' ~ t.id) }}">
                                    <button type="submit" class="tick{{ t.checkboxDone ? ' is-checked' }}" aria-pressed="{{ t.checkboxDone ? 'true' : 'false' }}" aria-label="Marcar «{{ t.title }}» como {{ t.checkboxDone ? 'no hecha' : 'hecha' }}">
                                        {% if t.checkboxDone %}<svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 10.5 l3.2 3.2 L15 6.5" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>{% endif %}
                                    </button>
                                </form>
                            {% else %}
                                <span class="tick is-static" aria-hidden="true"></span>
                            {% endif %}
                            <a class="tasklist__body" href="{{ path('task_show', { id: t.id }) }}">
                                <span class="tasklist__title">{{ t.title }}</span>
                                <span class="tasklist__meta">
                                    {%- if overdue %}VENCIÓ {{ t.dueDate|date('d/m') }}{% else %}HOY{% endif -%}
                                    {%- if t.unit %} · {{ t.unit.name }}{% endif -%}
                                    {%- if t.requiresDocument %} · adjuntar documento{% endif -%}
                                </span>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </section>

        {# ---- Módulo: Mi agenda (personal, malva) ---- #}
        <section class="module module--personal">
            <div class="module__head">
                <div class="module__ident">
                    <span class="module__icon module__icon--personal" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg>
                    </span>
                    <div>
                        <div class="module__title">Mi agenda</div>
                        <div class="module__sub">Recordatorios y citas · solo tú lo ves</div>
                    </div>
                </div>
                <a class="module__action" href="{{ path('personal_event_new') }}">+ Nuevo</a>
            </div>

            {% if agendaEvents is empty %}
                <p class="module__empty">Sin citas próximas.</p>
            {% else %}
                <ul class="agenda-rows">
                    {% for entry in agendaEvents %}
                        {% set e = entry.event %}
                        <li class="agenda-row">
                            <span class="agenda-row__time{{ e.allDay ? ' is-allday' }}">{{ e.allDay ? '—' : e.startAt|date('H:i') }}</span>
                            <a class="agenda-row__title" href="{{ path('personal_event_edit', { id: e.id }) }}">{{ e.title }}</a>
                            <span class="agenda-row__dot {{ e.category ? e.category.color.cssClass }}" aria-hidden="true"></span>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </section>

        {# ---- MÓDULO por rol: Guardias de hoy (coordinación) ---- #}
        {% if modules.guardiasToday is defined %}
            {% set g = modules.guardiasToday %}
            <section class="module">
                <div class="module__head">
                    <div class="module__ident">
                        <span class="module__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v6c0 4-3 7-7 9-4-2-7-5-7-9V6z"/></svg></span>
                        <div>
                            <div class="module__title">Guardias de hoy</div>
                            <div class="module__sub">Coordinación de guardias</div>
                        </div>
                    </div>
                </div>
                <div class="guardias-today">
                    {% if g.uncovered > 0 %}
                        <div class="guardias-today__count"><span class="guardias-today__dot"></span><span class="guardias-today__num">{{ g.uncovered }}</span><span class="guardias-today__label">ausencia{{ g.uncovered == 1 ? '' : 's' }} sin cubrir</span></div>
                        <a class="btn-mini" href="{{ path('guardia_index') }}">Repartir</a>
                    {% else %}
                        <div class="guardias-today__ok">✓ Todo cubierto hoy</div>
                        <a class="module__action" href="{{ path('guardia_index') }}">Ver parte</a>
                    {% endif %}
                </div>
            </section>
        {% endif %}

        {# ---- MÓDULO por rol: Mi departamento (jefe de departamento) ---- #}
        {% if modules.department is defined %}
            {% set d = modules.department %}
            <section class="module">
                <div class="module__head">
                    <div class="module__ident">
                        <span class="module__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20v-2a4 4 0 0 1 4-4h2M15 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM14 20v-1a4 4 0 0 1 8 0v1"/><circle cx="9" cy="8" r="3"/></svg>
                        </span>
                        <div>
                            <div class="module__title">Mi departamento</div>
                            <div class="module__sub">{{ d.dept.name }} · {{ d.people }} persona{{ d.people == 1 ? '' : 's' }}</div>
                        </div>
                    </div>
                </div>

                <div class="module__tiles">
                    <div class="module-tile">
                        <div class="module-tile__num module-tile__num--amber">{{ d.toValidate }}</div>
                        <div class="module-tile__label">por validar</div>
                    </div>
                    <div class="module-tile">
                        <div class="module-tile__num module-tile__num--accent">{{ d.teamOpen }}</div>
                        <div class="module-tile__label">pendientes equipo</div>
                    </div>
                </div>

                {% if d.pending is not empty %}
                    <div class="module__eyebrow">Pendientes de tu validación</div>
                    {% for t in d.pending %}
                        <a class="module-row" href="{{ path('task_show', { id: t.id }) }}">
                            <span class="module-row__avatar" aria-hidden="true">{{ t.assignedUser ? t.assignedUser.fullName|split(' ')|map(w => w|first)|join|slice(0, 2)|upper : '·' }}</span>
                            <span class="module-row__body">
                                <span class="module-row__title">{{ t.title }}</span>
                                <span class="module-row__sub">{% if t.assignedUser %}{{ t.assignedUser.fullName }} · {% endif %}entregada</span>
                            </span>
                            <span class="pill-validate">Validar</span>
                        </a>
                    {% endfor %}
                {% endif %}
                <a class="module__foot" href="{{ path('task_index') }}">Ver todo mi departamento</a>
            </section>
        {% endif %}

        {# ---- MÓDULO por rol: El centro (dirección / jefatura) ---- #}
        {% if modules.centre is defined %}
            {% set c = modules.centre %}
            <section class="module">
                <div class="module__head">
                    <div class="module__ident">
                        <span class="module__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V8l7-4 7 4v13M9 21v-5h6v5"/></svg>
                        </span>
                        <div>
                            <div class="module__title">El centro</div>
                            <div class="module__sub">Curso en vigor</div>
                        </div>
                    </div>
                </div>

                <div class="progress-block">
                    <div class="progress-block__head">
                        <span>Avance de tareas del curso</span>
                        <span class="progress-block__pct">{{ c.pct }}%</span>
                    </div>
                    <div class="progress-bar"><span class="progress-bar__fill" style="width: {{ c.pct }}%"></span></div>
                    <div class="progress-block__meta">{{ c.finalized }} de {{ c.total }} finalizadas</div>
                </div>

                <a class="module-row" href="{{ path('task_index') }}">
                    <span class="module-row__stat module-row__stat--amber">{{ c.toValidate }}</span>
                    <span class="module-row__body">
                        <span class="module-row__title">Pendientes de validación</span>
                        <span class="module-row__sub">entregadas esperando tu OK</span>
                    </span>
                    <span class="module-row__chevron" aria-hidden="true">›</span>
                </a>
                <a class="module-row" href="{{ path('task_index') }}">
                    <span class="module-row__stat module-row__stat--danger">{{ c.overdue }}</span>
                    <span class="module-row__body">
                        <span class="module-row__title">Tareas vencidas del centro</span>
                        <span class="module-row__sub">abiertas con fecha pasada</span>
                    </span>
                    <span class="module-row__chevron" aria-hidden="true">›</span>
                </a>
                <a class="module__foot" href="{{ path('task_index') }}">Ver panel del centro</a>
            </section>
        {% endif %}
    </div>
{% endblock %}
