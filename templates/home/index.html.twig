{% extends 'app_shell.html.twig' %}

{% block title %}Inicio · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}Inicio{% endblock %}

{% macro section(label, entries, tone) %}
    {% import '_macros/task.html.twig' as taskUi %}
    {% if entries is not empty %}
        <section class="agenda-group{{ tone ? ' agenda-group--' ~ tone }}">
            <h2 class="agenda-group__title">{{ label }} <span class="agenda-count">{{ entries|length }}</span></h2>
            <ol class="agenda-list">
                {% for entry in entries %}
                    {% if entry.kind == 'task' %}{{ taskUi.agenda_item(entry.task) }}{% else %}{{ taskUi.event_item(entry.event) }}{% endif %}
                {% endfor %}
            </ol>
        </section>
    {% endif %}
{% endmacro %}

{% block body %}
    {% set pendingCount = buckets.overdue|length + buckets.today|length + buckets.week|length + buckets.later|length %}

    <div class="page-head">
        <div>
            <h1>Hola, {{ firstName }}</h1>
            <p class="lead">
                {% if pendingCount == 0 %}Nada pendiente por ahora. Buen momento para respirar.
                {% else %}Esto es lo que tienes que hacer.{% endif %}
            </p>
        </div>
        <div class="page-head-actions">
            <a class="btn secondary" href="{{ path('personal_event_new') }}">+ Nuevo evento</a>
            <a class="btn" href="{{ path('task_new') }}">+ Nueva tarea</a>
        </div>
    </div>

    {% if pendingCount == 0 and buckets.done is empty %}
        <div class="card">
            <div class="empty-state">
                <h2>Aún no tienes tareas asignadas</h2>
                <p>Cuando dirección planifique tareas para ti o para tus responsabilidades, aparecerán aquí, ordenadas por fecha.</p>
            </div>
        </div>
    {% else %}
        {{ _self.section('Vencidas', buckets.overdue, 'overdue') }}
        {{ _self.section('Hoy', buckets.today) }}
        {{ _self.section('Próximos 7 días', buckets.week) }}
        {{ _self.section('Más adelante', buckets.later) }}

        {% if pendingCount == 0 %}
            <div class="card"><div class="empty-state"><h2>¡Todo hecho! 🎉</h2><p>No te queda nada pendiente. Lo marcado como hecho está abajo.</p></div></div>
        {% endif %}

        {{ _self.section('Hechas', buckets.done, 'done') }}
    {% endif %}
{% endblock %}
