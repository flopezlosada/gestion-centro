{#
   Scaffold de formulario compartido. Reemplaza el boilerplate que estaba copiado en cada
   plantilla de alta/edición: la fila de campo (.form-row con etiqueta, widget, ayuda y errores)
   y la barra de acciones (Guardar / Cancelar). Así una mejora de UX en los formularios se hace
   en UN sitio y aplica a todos.

   Uso típico:
     {% import '_macros/form.html.twig' as f %}
     <div class="card form-card">
         {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
             {{ form_errors(form) }}
             {{ f.fields([form.foo, form.bar]) }}
             {{ f.actions(path('algo_index')) }}
         {{ form_end(form) }}
     </div>
#}

{#
   Renderiza una lista de campos, cada uno en su .form-row (etiqueta + widget + ayuda + errores).
   Se pasa la lista explícita para preservar el orden y la selección exactos de cada formulario.
#}
{% macro fields(list) %}
    {% for field in list %}
        <div class="form-row">
            {{ form_label(field) }}
            {{ form_widget(field) }}
            {% if field.vars.help %}<p class="help">{{ field.vars.help }}</p>{% endif %}
            {{ form_errors(field) }}
        </div>
    {% endfor %}
{% endmacro %}

{#
   Un campo compacto para la fila de metadatos del alta rápida (quick-add): etiqueta pequeña +
   control + errores. Sin la ayuda larga (estorba en el layout en fila; va en el placeholder o se omite).
#}
{#
   Un campo apilado (etiqueta + control + ayuda + errores), como `fields` pero de uno en uno y con
   soporte para ocultado condicional: `when` pone data-qa-when, y agenda-form.js lo muestra solo
   cuando se cumple la condición (p. ej. las horas solo si NO es "todo el día"). Sin JS, se ve siempre.
#}
{% macro field(field, when = null) %}
    <div class="form-row"{% if when %} data-qa-when="{{ when }}"{% endif %}>
        {{ form_label(field) }}
        {{ form_widget(field) }}
        {% if field.vars.help %}<p class="help">{{ field.vars.help }}</p>{% endif %}
        {{ form_errors(field) }}
    </div>
{% endmacro %}

{#
   Agrupa un bloque de campos bajo un título, para partir los formularios largos en secciones
   y que no sean un muro de campos. Usa <fieldset>/<legend> (semántica de agrupación accesible).
#}
{% macro section(title, list) %}
    <fieldset class="form-section">
        <legend class="form-section-title">{{ title }}</legend>
        {{ _self.fields(list) }}
    </fieldset>
{% endmacro %}

{#
   Un campo booleano como interruptor (switch) en vez del checkbox cuadrado nativo del navegador.
   El <input type="checkbox"> real sigue en el DOM (solo oculto visualmente vía .switch__input), así
   que es accesible y se envía como cualquier checkbox: no hay JS de por medio, la pista la pinta el
   CSS con :checked. La etiqueta y la ayuda salen del propio campo (field.vars), y el <label> envuelve
   al input para que al pulsar en todo el bloque conmute.
#}
{% macro toggle(field) %}
    <div class="switch-row">
        <label class="switch">
            {{ form_widget(field, { attr: { class: 'switch__input' } }) }}
            <span class="switch__track" aria-hidden="true"><span class="switch__thumb"></span></span>
            <span class="switch__text">
                <span class="switch__label">{{ field.vars.label }}</span>
                {% if field.vars.help %}<span class="switch__help">{{ field.vars.help }}</span>{% endif %}
            </span>
        </label>
        {{ form_errors(field) }}
    </div>
{% endmacro %}

{#
   Un grupo de campos booleanos como interruptores (ver `toggle`). Se pasa la lista explícita para
   preservar el orden. Úsalo para las "opciones" de un formulario (obligatoria, lleva entregable…).
#}
{% macro toggles(list) %}
    <div class="switches">
        {% for field in list %}
            {{ _self.toggle(field) }}
        {% endfor %}
    </div>
{% endmacro %}

{#
   Barra de acciones del formulario: el botón primario de envío y un enlace de cancelar.
   cancelUrl: destino del enlace "Cancelar". submitLabel: texto del botón (por defecto "Guardar").
#}
{% macro actions(cancelUrl, submitLabel = 'Guardar') %}
    <div class="form-actions">
        <button class="btn" type="submit">{{ submitLabel }}</button>
        <a class="btn secondary" href="{{ cancelUrl }}">Cancelar</a>
    </div>
{% endmacro %}

{#
   El bloque "Responsable" de la tarea: la cascada rol → departamento. El paso de departamento va
   marcado con data-dept-step para que task-form.js lo muestre solo si el rol elegido es de
   departamento. Sin JS se ve siempre y la validación guía.
#}
{% macro responsibility(form) %}
    {{ _self.field(form.responsibilityRole) }}
    {% if form.responsibilityUnit is defined %}
        <div class="form-row" data-dept-step="1">
            {{ form_label(form.responsibilityUnit) }}
            {{ form_widget(form.responsibilityUnit) }}
            {% if form.responsibilityUnit.vars.help %}<p class="help">{{ form.responsibilityUnit.vars.help }}</p>{% endif %}
            {{ form_errors(form.responsibilityUnit) }}
        </div>
    {% endif %}
    {#- Vista previa (task-form.js): a quién resuelve el rol + departamento elegido. -#}
    <div class="form-row" data-responsibles data-responsibles-url="{{ path('task_responsibles') }}">
        <span class="form-label-lite">Responsable(s)</span>
        <p class="responsables" data-responsibles-list>—</p>
    </div>
{% endmacro %}
