{#
   Helpers de presentación de tareas, compartidos por la agenda, el plan y la ficha:
   la etiqueta humana del estado y su badge de color (reusa las clases de app.css).
#}

{% macro status_label(status) %}
    {#- Etiquetas en App\Support\TaskStatus::LABELS (única fuente, compartida con el presenter). -#}
    {%- set labels = constant('App\\Support\\TaskStatus::LABELS') -%}
    {{- labels[status]|default(status) -}}
{% endmacro %}

{% macro agenda_item(task, canWork = true) %}
    {#- Una fila de agenda: casilla "Hecho" (1 clic, POST) + título enlazado + cuándo/dónde.
        Compartida por la agenda de Inicio y la vista de día del calendario. El botón accionable solo
        se ofrece si `canWork` (mismo criterio que TaskController::canWorkOn); si no, la casilla se
        muestra estática (refleja el estado, no acciona). El defaulta a true porque Inicio solo lista
        tareas propias; el calendario, que muestra también tareas visibles por jerarquía ajenas, pasa
        el flag calculado. Se recibe por parámetro (no vía `is_granted`/`app` aquí dentro) porque las
        macros de Twig están aisladas del contexto: el cálculo vive en el cuerpo de la plantilla. -#}
    {% set canToggle = task.requiresCheckbox and canWork %}
    <li class="agenda-item{{ task.checkboxDone ? ' is-done' }}" id="tarea-{{ task.id }}">
        {% if canToggle %}
            <form method="post" action="{{ path('task_toggle_done', { id: task.id }) }}" class="agenda-check">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle_done' ~ task.id) }}">
                <button type="submit" class="checkbox{{ task.checkboxDone ? ' is-checked' }}"
                        aria-pressed="{{ task.checkboxDone ? 'true' : 'false' }}"
                        title="{{ task.checkboxDone ? 'Hecho — pulsa para deshacer' : 'Marcar como hecho (reversible)' }}"
                        aria-label="Marcar «{{ task.title }}» como {{ task.checkboxDone ? 'no hecha' : 'hecha' }}">
                    <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 10.5 l3.2 3.2 L15 6.5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
            </form>
        {% else %}
            <span class="checkbox is-static{{ task.requiresCheckbox and task.checkboxDone ? ' is-checked' }}" aria-hidden="true">
                {% if task.requiresCheckbox and task.checkboxDone %}<svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 10.5 l3.2 3.2 L15 6.5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>{% endif %}
            </span>
        {% endif %}
        <div class="agenda-body">
            <a href="{{ path('task_show', { id: task.id }) }}" class="agenda-title">{{ task.title }}</a>
            <span class="agenda-meta">
                {{ task.dueDate|date('d/m/Y') }}{% if task.unit %} · {{ task.unit.name }}{% endif %}{% if not task.mandatory %} · voluntaria{% endif %}
            </span>
        </div>
    </li>
{% endmacro %}

{% macro event_item(event) %}
    {#- Fila de agenda para un evento PERSONAL (privado de su dueño): casilla "Hecho" de 1 clic +
        título enlazado a su edición + cuándo (el día, y la hora si la tiene; un recordatorio sin hora
        solo muestra el día), con un badge de categoría. A diferencia de `agenda_item`, el evento no tiene
        workflow ni estado: solo el `done`. La casilla siempre acciona porque estos eventos solo se
        listan a su propio dueño (nadie más los ve). Tras marcar, el controlador vuelve siempre a la
        agenda anclando en esta fila. -#}
    <li class="agenda-item{{ event.done ? ' is-done' }}" id="evento-{{ event.id }}">
        <form method="post" action="{{ path('personal_event_toggle_done', { id: event.id }) }}" class="agenda-check">
            <input type="hidden" name="_token" value="{{ csrf_token('personal_event_done' ~ event.id) }}">
            <button type="submit" class="checkbox{{ event.done ? ' is-checked' }}"
                    aria-pressed="{{ event.done ? 'true' : 'false' }}"
                    title="{{ event.done ? 'Hecho — pulsa para deshacer' : 'Marcar como hecho (reversible)' }}"
                    aria-label="Marcar «{{ event.title }}» como {{ event.done ? 'no hecho' : 'hecho' }}">
                <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 10.5 l3.2 3.2 L15 6.5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
        </form>
        <div class="agenda-body">
            <a href="{{ path('personal_event_edit', { id: event.id }) }}" class="agenda-title">{{ event.title }}</a>
            <span class="agenda-meta">
                {{ event.startAt|date('d/m/Y') }}
                {%- if not event.allDay %} · {{ event.startAt|date('H:i') }}{% if event.endAt %}–{{ event.endAt|date('H:i') }}{% endif %}{% endif %}
                {%- if event.category %} · <span class="event-badge {{ event.category.color.cssClass }}">{{ event.category.name }}</span>{% endif %}
            </span>
        </div>
    </li>
{% endmacro %}

{#
   Un bloque de la agenda personal: un tramo (Hoy, Vencidas…) con su cuenta y las entradas, cada una
   pintada según su tipo (tarea o evento). `entries` es una lista de App\Agenda\AgendaEntry.
#}
{% macro agenda_section(label, entries, tone) %}
    {% if entries is not empty %}
        <section class="agenda-group{{ tone ? ' agenda-group--' ~ tone }}">
            <h2 class="agenda-group__title">{{ label }} <span class="agenda-count">{{ entries|length }}</span></h2>
            <ol class="agenda-list">
                {% for entry in entries %}
                    {% if entry.kind == 'task' %}{{ _self.agenda_item(entry.task) }}{% else %}{{ _self.event_item(entry.event) }}{% endif %}
                {% endfor %}
            </ol>
        </section>
    {% endif %}
{% endmacro %}

{% macro status_dot(status) %}
    {#- Puntito de color por estado para vistas compactas (calendario). Comparte la escala
        semántica del badge; el valor del estado es la propia clase modificadora. -#}
    <span class="calendar-dot calendar-dot--{{ status }}" title="{{ _self.status_label(status) }}"></span>
{% endmacro %}

{% macro action_label(name) %}
    {%- set labels = {
        'start': 'Empezar',
        'complete': 'Marcar hecha',
        'submit': 'Entregar',
        'validate': 'Validar',
        'reject': 'Devolver',
        'reopen': 'Reabrir',
        'rework': 'Retomar',
    } -%}
    {{- labels[name]|default(name) -}}
{% endmacro %}

{% macro status_badge(status) %}
    {%- set classes = {
        'pending': 'badge--muted',
        'in_progress': 'badge--review',
        'submitted': 'badge--warning',
        'done': 'badge--success',
        'validated': 'badge--done',
        'rejected': 'badge--danger',
    } -%}
    <span class="badge {{ classes[status]|default('badge--muted') }}">{{ _self.status_label(status) }}</span>
{% endmacro %}
