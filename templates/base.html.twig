<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ app_organization_name }}{% endblock %}</title>
        <link rel="icon" href="/favicon.svg" type="image/svg+xml">

        {# PWA: instalable (necesario para que el push funcione en iOS ≥16.4, que exige la web añadida a
           la pantalla de inicio) y notificaciones push por web. #}
        <link rel="manifest" href="/manifest.webmanifest">
        <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
        <meta name="theme-color" content="#1E4A3D">
        {% if app.user and app_vapid_public_key is not empty %}
            <meta name="vapid-public-key" content="{{ app_vapid_public_key }}">
            <meta name="push-csrf" content="{{ csrf_token('push') }}">
            <meta name="push-subscribe-url" content="{{ path('push_subscribe') }}">
            <meta name="push-unsubscribe-url" content="{{ path('push_unsubscribe') }}">
        {% endif %}

        {# Anti-FOUC: fija el tema antes de pintar, según la elección guardada o la preferencia del sistema. #}
        <script>
            (function () {
                try {
                    var saved = localStorage.getItem('gc-theme');
                    var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                    document.documentElement.setAttribute('data-theme', theme);
                } catch (e) { document.documentElement.setAttribute('data-theme', 'light'); }
            })();
        </script>

        {% block stylesheets %}
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Instrument+Sans:wght@400;500;600&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600&display=swap" rel="stylesheet">
            <link rel="stylesheet" href="{{ asset_ver('/css/app.css') }}">
        {% endblock %}
    </head>
    <body>
        {% block shell %}{% endblock %}

        {% block javascripts %}
            <script src="{{ asset_ver('/js/theme.js') }}"></script>
            <script src="{{ asset_ver('/js/nav.js') }}"></script>
            <script src="{{ asset_ver('/js/responsive-tables.js') }}"></script>
            {# select-menu antes de table-tools: éste invoca window.enhanceSelectMenus para su filtro. #}
            <script src="{{ asset_ver('/js/select-menu.js') }}"></script>
            <script src="{{ asset_ver('/js/date-field.js') }}"></script>
            <script src="{{ asset_ver('/js/agenda-form.js') }}"></script>
            <script src="{{ asset_ver('/js/task-form.js') }}"></script>
            <script src="{{ asset_ver('/js/table-tools.js') }}"></script>
            <script src="{{ asset_ver('/js/confirm-dialog.js') }}"></script>
            <script src="{{ asset_ver('/js/calendar-filter.js') }}"></script>
            <script src="{{ asset_ver('/js/day-add.js') }}"></script>
            {% if app.user and app_vapid_public_key is not empty %}
                <script src="{{ asset_ver('/js/push.js') }}" defer></script>
            {% endif %}
        {% endblock %}

        {# Scripts propios de una página (p. ej. la librería de gráficos de estadísticas): así no se
           cargan en todas las páginas. Se colocan tras los globales para poder depender de ellos. #}
        {% block page_scripts %}{% endblock %}
    </body>
</html>
