<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ app_organization_name }}{% endblock %}</title>
        <link rel="icon" href="/favicon.svg" type="image/svg+xml">

        {# Anti-FOUC: fija el tema antes de pintar, según la elección guardada o la preferencia del sistema. #}
        <script>
            (function () {
                try {
                    var saved = localStorage.getItem('gc-theme');
                    var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                    document.documentElement.setAttribute('data-theme', theme);
                } catch (e) { document.documentElement.setAttribute('data-theme', 'light'); }
            })();
        </script>

        {% block stylesheets %}
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet">
            <link rel="stylesheet" href="{{ asset_ver('/css/app.css') }}">
        {% endblock %}
    </head>
    <body>
        {% block shell %}{% endblock %}

        {% block javascripts %}
            <script src="{{ asset_ver('/js/theme.js') }}"></script>
            <script src="{{ asset_ver('/js/nav.js') }}"></script>
            <script src="{{ asset_ver('/js/responsive-tables.js') }}"></script>
            {# select-menu antes de table-tools: éste invoca window.enhanceSelectMenus para su filtro. #}
            <script src="{{ asset_ver('/js/select-menu.js') }}"></script>
            <script src="{{ asset_ver('/js/date-field.js') }}"></script>
            <script src="{{ asset_ver('/js/agenda-form.js') }}"></script>
            <script src="{{ asset_ver('/js/task-form.js') }}"></script>
            <script src="{{ asset_ver('/js/table-tools.js') }}"></script>
            <script src="{{ asset_ver('/js/confirm-dialog.js') }}"></script>
            <script src="{{ asset_ver('/js/calendar-filter.js') }}"></script>
            <script src="{{ asset_ver('/js/day-add.js') }}"></script>
        {% endblock %}
    </body>
</html>
