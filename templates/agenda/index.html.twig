{% extends 'app_shell.html.twig' %}
{% import '_macros/task.html.twig' as taskUi %}

{% block title %}Mi agenda · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span>Agenda{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Mi agenda</h1>
            <p class="lead">Tus citas y recordatorios. Privados: solo los ves tú.</p>
        </div>
        <div><a class="btn" href="{{ path('personal_event_new') }}">+ Nuevo evento</a></div>
    </div>

    <div class="card">
        {% if events is empty %}
            <div class="empty-state">
                <h2>No tienes nada próximo</h2>
                <p>Crea un evento para tu tutoría, una reunión o un recordatorio.</p>
            </div>
        {% else %}
            <ul class="agenda-list">
                {# Una sola fuente de verdad para la fila de evento: el mismo macro que usa Inicio.
                   returnTo='agenda' para que al marcar "hecho" se vuelva aquí. #}
                {% for e in events %}{{ taskUi.event_item(e, 'agenda') }}{% endfor %}
            </ul>
        {% endif %}
    </div>
{% endblock %}
