{% extends 'app_shell.html.twig' %}
{% import '_macros/task.html.twig' as taskUi %}

{% block title %}Agenda personal · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}Agenda personal{% endblock %}

{% block body %}
    {% set pendingCount = buckets.overdue|length + buckets.today|length + buckets.week|length + buckets.later|length %}

    <div class="page-head">
        <div>
            <h1>Agenda personal</h1>
            <p class="lead">Lo que tienes que hacer: las tareas que te asignan y los recordatorios o citas que te pongas tú. Lo tuyo es privado, solo lo ves tú.</p>
        </div>
        <div><a class="btn" href="{{ path('personal_event_new') }}">+ Nuevo</a></div>
    </div>

    {% if pendingCount == 0 and buckets.done is empty %}
        <div class="card">
            <div class="empty-state">
                <h2>No tienes nada por ahora</h2>
                <p>Aquí verás las tareas que te asignen y los recordatorios o citas que te pongas tú.</p>
                <a class="btn" href="{{ path('personal_event_new') }}">Añadir algo</a>
            </div>
        </div>
    {% else %}
        {{ taskUi.agenda_section('Vencidas', buckets.overdue, 'overdue') }}
        {{ taskUi.agenda_section('Hoy', buckets.today) }}
        {{ taskUi.agenda_section('Próximos 7 días', buckets.week) }}
        {{ taskUi.agenda_section('Más adelante', buckets.later) }}

        {% if pendingCount == 0 %}
            <div class="card"><div class="empty-state"><h2>¡Todo hecho! 🎉</h2><p>No te queda nada pendiente. Lo marcado como hecho está abajo.</p></div></div>
        {% endif %}

        {{ taskUi.agenda_section('Hechas', buckets.done, 'done') }}
    {% endif %}
{% endblock %}
