{% extends 'app_shell.html.twig' %}
{% import '_macros/form.html.twig' as f %}

{% block title %}Editar evento · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('personal_event_index') }}">Agenda</a><span class="sep">/</span>Editar{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Editar evento</h1>
            <p class="lead">
                {% if event.recurring %}Este evento se repite; los cambios afectan solo a esta fecha.
                {% else %}Cambia los datos de tu evento.{% endif %}
            </p>
        </div>
    </div>

    <div class="card">
        {{ form_start(form) }}
        {{ form_errors(form) }}
        <div class="stackform">
            <div class="form-row">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, { attr: { class: 'field-title' } }) }}
                {{ form_errors(form.title) }}
            </div>
            {{ f.field(form.description) }}
            {{ f.field(form.day) }}
            {{ f.field(form.startTime) }}
            {{ f.field(form.endTime, 'hasstart') }}
            {{ f.field(form.category) }}
            <div class="stackform__foot">
                <a class="btn secondary" href="{{ path('personal_event_index') }}">Cancelar</a>
                <button class="btn" type="submit">Guardar</button>
            </div>
        </div>
        {{ form_end(form) }}
    </div>

    <div class="card">
        <div class="page-head"><div><h2>Borrar</h2><p class="lead">Elimina el evento. No se puede deshacer.</p></div></div>
        <div class="form-actions">
            <form method="post" action="{{ path('personal_event_delete', { id: event.id }) }}" data-confirm="¿Seguro que quieres borrar «{{ event.title }}»?">
                <input type="hidden" name="_token" value="{{ csrf_token('personal_event_delete' ~ event.id) }}">
                <button type="submit" class="btn btn-danger">Borrar {{ event.recurring ? 'solo este' : 'evento' }}</button>
            </form>
            {% if event.recurring %}
                <form method="post" action="{{ path('personal_event_delete_series', { id: event.id }) }}" data-confirm="¿Borrar TODA la serie de «{{ event.title }}»? No se puede deshacer.">
                    <input type="hidden" name="_token" value="{{ csrf_token('personal_event_delete_series' ~ event.id) }}">
                    <button type="submit" class="btn btn-danger">Borrar toda la serie</button>
                </form>
            {% endif %}
        </div>
    </div>
{% endblock %}
