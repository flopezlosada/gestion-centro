{% extends 'app_shell.html.twig' %}
{% import '_macros/form.html.twig' as f %}

{% block title %}Nuevo evento · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('personal_event_index') }}">Agenda</a><span class="sep">/</span>Nuevo{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Nuevo evento</h1>
            <p class="lead">Una cita, tutoría o recordatorio tuyo. Solo lo ves tú.</p>
        </div>
    </div>

    <div class="card">
        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
        {{ f.submit_error(form) }}
        {{ form_errors(form) }}
        <div class="stackform">
            <div class="form-row">
                {{ form_label(form.title) }}
                {{ form_widget(form.title, { attr: { class: 'field-title', placeholder: 'Ej. Tutoría con la familia de…', autofocus: true } }) }}
                {{ form_errors(form.title) }}
            </div>
            {{ f.field(form.description) }}
            {{ f.field(form.day) }}
            {{ f.field(form.startTime) }}
            {{ f.field(form.endTime, 'hasstart') }}
            {{ f.field(form.category) }}
            {% if form.repeat is defined %}{{ f.field(form.repeat) }}{% endif %}
            {% if form.repeatUntil is defined %}{{ f.field(form.repeatUntil, 'repeating') }}{% endif %}
            <div class="stackform__foot">
                <a class="btn secondary" href="{{ path('personal_event_index') }}">Cancelar</a>
                <button class="btn" type="submit">Crear evento</button>
            </div>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
