{% extends 'app_shell.html.twig' %}
{% import '_macros/form.html.twig' as f %}

{% block title %}Nuevo evento · {{ app_organization_name }}{% endblock %}
{% block breadcrumb %}<a href="{{ path('app_homepage') }}">Inicio</a><span class="sep">/</span><a href="{{ path('personal_event_index') }}">Agenda</a><span class="sep">/</span>Nuevo{% endblock %}

{% block body %}
    <div class="page-head">
        <div>
            <h1>Nuevo evento</h1>
            <p class="lead">Una cita, tutoría o recordatorio tuyo. Solo lo ves tú.</p>
        </div>
    </div>

    <div class="card">
        {{ form_start(form) }}
        {{ form_errors(form) }}
        {{ f.section('Qué', [form.title, form.description, form.category]) }}
        <fieldset class="form-section">
            <legend class="form-section-title">Cuándo</legend>
            {{ f.fields([form.day]) }}
            {{ f.toggles([form.allDay]) }}
            {{ f.fields([form.startTime, form.endTime]) }}
        </fieldset>
        {% if form.repeat is defined %}
            <fieldset class="form-section">
                <legend class="form-section-title">Repetición</legend>
                {{ f.fields([form.repeat, form.repeatUntil]) }}
            </fieldset>
        {% endif %}
        {{ f.actions(path('personal_event_index'), 'Crear evento') }}
        {{ form_end(form) }}
    </div>
{% endblock %}
